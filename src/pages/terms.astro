---
export const prerender = true;
const updated = 'March 11, 2026';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Terms of Service — Las Vegas Landscaping</title>
  <meta name="description" content="Terms of Service for Las Vegas Landscaping — a free lead generation service connecting homeowners with local licensed landscaping contractors in Las Vegas, NV." />
  <meta name="robots" content="noindex, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --g900: #0f2a1e; --g800: #1a4731; --g700: #2d6b4e; --g600: #3d8c62;
      --g100: #e8f4ee; --g50: #f4faf6;
      --gold: #d4a017; --gold2: #f0c040;
      --text: #1a1a1a; --muted: #6b7280; --border: #e2e8f0;
      --radius: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; color: var(--text); background: #fff; line-height: 1.6; }
    a { color: var(--g700); }

    /* Header */
    .site-header { background: var(--g900); padding: 0 24px; position: sticky; top: 0; z-index: 100; }
    .header-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 60px; gap: 16px; }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-text-wrap .logo-name { font-weight: 800; font-size: 1rem; color: white; display: block; }
    .logo-text-wrap .logo-sub { font-size: 0.7rem; color: rgba(255,255,255,0.55); }
    nav { display: flex; align-items: center; gap: 20px; }
    nav a { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: white; }
    .btn-call { background: var(--gold); color: var(--g900) !important; padding: 8px 16px; border-radius: 6px; font-weight: 700 !important; font-size: 0.8rem !important; white-space: nowrap; }

    /* Hero */
    .hero { background: linear-gradient(135deg, var(--g900) 0%, var(--g800) 60%, var(--g700) 100%); color: white; padding: 64px 24px 48px; text-align: center; }
    .hero h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; line-height: 1.2; margin-bottom: 12px; }
    .hero p { font-size: 0.9rem; color: rgba(255,255,255,0.65); }

    /* Content */
    .content { max-width: 780px; margin: 0 auto; padding: 56px 24px 80px; }
    .section { margin-bottom: 40px; }
    .section h2 { font-size: 1.2rem; font-weight: 700; color: var(--g800); margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid var(--g100); }
    .section p { color: #444; margin-bottom: 12px; font-size: 0.93rem; }
    .section ul { color: #444; font-size: 0.93rem; padding-left: 20px; margin-bottom: 12px; }
    .section ul li { margin-bottom: 6px; }

    /* Disclosure box */
    .disclosure { background: #fff8e1; border: 2px solid var(--gold); border-radius: var(--radius); padding: 20px 24px; margin-bottom: 40px; }
    .disclosure-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gold); margin-bottom: 8px; }
    .disclosure p { color: #4a3800; font-size: 0.93rem; margin: 0; line-height: 1.6; }

    /* TOC */
    .toc { background: var(--g50); border: 1px solid var(--g100); border-radius: var(--radius); padding: 20px 24px; margin-bottom: 40px; }
    .toc-title { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 10px; }
    .toc ol { padding-left: 20px; }
    .toc li { font-size: 0.875rem; margin-bottom: 4px; }
    .toc a { color: var(--g700); text-decoration: none; font-weight: 500; }
    .toc a:hover { text-decoration: underline; }

    /* Footer */
    footer { background: var(--g900); color: rgba(255,255,255,0.6); text-align: center; padding: 28px 24px; font-size: 0.8rem; }
    footer a { color: var(--gold2); text-decoration: none; font-weight: 600; margin: 0 8px; }
    .footer-links { margin: 10px 0; }
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <svg width="32" height="32" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="19" cy="19" r="19" fill="#2d6b4e"/>
        <path d="M19 8C13 8 8 13 8 19s5 11 11 11c1.8 0 3.5-.5 5-1.3L19 24l-3-6 6-3 3 6-3 3.7C25.5 23 27 21 27 19c0-6-4-10.5-8-11z" fill="white"/>
        <path d="M19 8c.7 3 1.8 10-3 14.5" stroke="#d4a017" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
      <div class="logo-text-wrap">
        <span class="logo-name">Las Vegas Landscaping</span>
        <span class="logo-sub">Licensed • Insured</span>
      </div>
    </a>
    <nav>
      <a href="/">Home</a>
      <a href="/areas">Service Areas</a>
      <a href="tel:7025288324" class="btn-call">📞 (702) 528-8324</a>
    </nav>
  </div>
</header>

<section class="hero">
  <h1>Terms of Service</h1>
  <p>Last updated: {updated}</p>
</section>

<div class="content">

  <div class="disclosure">
    <div class="disclosure-label">⚠ Key Terms — Please Read</div>
    <p><strong>Las Vegas Landscaping is a free lead generation service, not a landscaping contractor.</strong> By submitting a request on this website, you consent to be contacted by one or more local licensed landscaping contractors in the Las Vegas area by phone, text, or email. Estimates generated on this site are AI-powered approximations and are not binding quotes.</p>
  </div>

  <div class="toc">
    <div class="toc-title">Contents</div>
    <ol>
      <li><a href="#nature-of-service">Nature of This Service</a></li>
      <li><a href="#consent-to-contact">Consent to Be Contacted</a></li>
      <li><a href="#ai-estimates">AI Estimates Disclaimer</a></li>
      <li><a href="#no-relationship">No Contractor Relationship</a></li>
      <li><a href="#no-guarantees">No Guarantees</a></li>
      <li><a href="#liability">Limitation of Liability</a></li>
      <li><a href="#user-conduct">User Conduct</a></li>
      <li><a href="#governing-law">Governing Law</a></li>
      <li><a href="#changes">Changes to These Terms</a></li>
      <li><a href="#contact">Contact</a></li>
    </ol>
  </div>

  <div class="section" id="nature-of-service">
    <h2>1. Nature of This Service</h2>
    <p>Las Vegas Landscaping (the "Service"), accessible at lasvegaslandscaping.homepropeople.com, is operated as a <strong>free lead generation platform</strong>. We are not a landscaping contractor and do not perform any landscaping work.</p>
    <p>Our Service collects estimate requests from homeowners and property owners in the Las Vegas Valley and forwards those requests to independent, locally licensed landscaping contractors. The contractors are independent third parties, not employees or agents of Las Vegas Landscaping.</p>
    <p>By accessing or using this website, you agree to these Terms of Service. If you do not agree, please do not use the website.</p>
  </div>

  <div class="section" id="consent-to-contact">
    <h2>2. Consent to Be Contacted</h2>
    <p>By submitting an estimate request on this website, you expressly consent to be contacted by one or more local licensed landscaping contractors regarding your project. This contact may be made by:</p>
    <ul>
      <li>Phone call (including automated or pre-recorded calls where permitted by law)</li>
      <li>Text message (SMS)</li>
      <li>Email</li>
    </ul>
    <p>You understand that submitting a request constitutes a request to be contacted. You may opt out of further contact at any time by notifying the contractor directly or by emailing us at <a href="mailto:info@lasvegaslandscaping.homepropeople.com">info@lasvegaslandscaping.homepropeople.com</a>.</p>
    <p>Your consent to be contacted is not a condition of any purchase. This service is entirely free.</p>
  </div>

  <div class="section" id="ai-estimates">
    <h2>3. AI Estimates Disclaimer</h2>
    <p>This website uses artificial intelligence (specifically, Anthropic's Claude AI) to generate instant cost estimates based on the information you provide. <strong>These estimates are approximations only.</strong></p>
    <ul>
      <li>AI estimates are not binding quotes or contracts.</li>
      <li>Actual project costs will vary based on site conditions, material prices, labor, scope of work, and other factors that can only be assessed by an on-site visit.</li>
      <li>Las Vegas Landscaping makes no warranty that AI estimates will be accurate, complete, or reflective of actual contractor pricing.</li>
      <li>Only a written contract between you and a licensed contractor establishes binding pricing.</li>
    </ul>
  </div>

  <div class="section" id="no-relationship">
    <h2>4. No Contractor-Client Relationship with This Website</h2>
    <p>Using this website does not create any contractor-client, agent-principal, employer-employee, partnership, or joint venture relationship between you and Las Vegas Landscaping.</p>
    <p>Any agreement for landscaping services, including pricing, scope of work, timelines, and warranties, is solely between you and the independent contractor you choose to hire. Las Vegas Landscaping is not a party to any such agreement.</p>
    <p>Las Vegas Landscaping does not supervise, direct, control, or guarantee the work of any contractor you connect with through this service.</p>
  </div>

  <div class="section" id="no-guarantees">
    <h2>5. No Guarantees</h2>
    <p>Las Vegas Landscaping does not guarantee:</p>
    <ul>
      <li>That you will receive a response from a contractor</li>
      <li>The quality, timeliness, or cost of any contractor's work</li>
      <li>That any contractor is currently licensed or insured (we encourage you to verify independently)</li>
      <li>The accuracy of AI-generated estimates</li>
      <li>Uninterrupted availability of the website</li>
    </ul>
    <p>The Service is provided "as is" and "as available" without warranties of any kind, express or implied.</p>
  </div>

  <div class="section" id="liability">
    <h2>6. Limitation of Liability</h2>
    <p>To the fullest extent permitted by applicable law, Las Vegas Landscaping and its operators shall not be liable for:</p>
    <ul>
      <li>Any indirect, incidental, special, consequential, or punitive damages</li>
      <li>Any damages resulting from contractor work quality, disputes, or failure to perform</li>
      <li>Any damages arising from reliance on AI-generated estimates</li>
      <li>Any loss of data, profits, or business opportunities</li>
    </ul>
    <p>Our total liability in any matter arising from use of this Service shall not exceed zero dollars ($0), as this is a free service.</p>
  </div>

  <div class="section" id="user-conduct">
    <h2>7. User Conduct</h2>
    <p>When using this website, you agree not to:</p>
    <ul>
      <li>Submit false, misleading, or fraudulent information</li>
      <li>Submit requests on behalf of others without their authorization</li>
      <li>Use the website for any unlawful purpose</li>
      <li>Attempt to interfere with or disrupt the website's operation</li>
    </ul>
  </div>

  <div class="section" id="governing-law">
    <h2>8. Governing Law</h2>
    <p>These Terms of Service are governed by the laws of the State of Nevada, without regard to conflict of law principles. Any disputes arising from use of this Service shall be resolved in the state or federal courts located in Clark County, Nevada.</p>
  </div>

  <div class="section" id="changes">
    <h2>9. Changes to These Terms</h2>
    <p>We may update these Terms of Service from time to time. When we do, we will update the "Last updated" date at the top of this page. Your continued use of the website after changes are posted constitutes your acceptance of the updated terms.</p>
  </div>

  <div class="section" id="contact">
    <h2>10. Contact</h2>
    <p>If you have questions about these Terms of Service, please contact us:</p>
    <ul>
      <li><strong>Email:</strong> <a href="mailto:info@lasvegaslandscaping.homepropeople.com">info@lasvegaslandscaping.homepropeople.com</a></li>
      <li><strong>Phone:</strong> <a href="tel:7025288324">(702) 528-8324</a></li>
    </ul>
  </div>

</div>

<footer>
  <div>
    <a href="/">Home</a>
    <a href="/areas">Service Areas</a>
    <a href="/rebate-calculator">Rebate Calculator</a>
    <a href="tel:7025288324">(702) 528-8324</a>
  </div>
  <div class="footer-links">
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/privacy-policy">Privacy Policy</a>
    <a href="/terms">Terms of Service</a>
  </div>
  &copy; {new Date().getFullYear()} Las Vegas Landscaping — Licensed &bull; Bonded &bull; Insured &bull; Nevada AB356 Compliant
</footer>

</body>
</html>
