---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Us — Las Vegas Landscaping</title>
  <meta name="description" content="Las Vegas Landscaping is a free lead generation service connecting Las Vegas homeowners with local licensed landscaping contractors for free estimates." />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --g900: #0f2a1e; --g800: #1a4731; --g700: #2d6b4e; --g600: #3d8c62;
      --g100: #e8f4ee; --g50: #f4faf6;
      --gold: #d4a017; --gold2: #f0c040;
      --text: #1a1a1a; --muted: #6b7280; --border: #e2e8f0;
      --radius: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; color: var(--text); background: #fff; line-height: 1.6; }
    a { color: inherit; }

    /* Header */
    .site-header { background: var(--g900); padding: 0 24px; position: sticky; top: 0; z-index: 100; }
    .header-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 60px; gap: 16px; }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-text-wrap .logo-name { font-weight: 800; font-size: 1rem; color: white; display: block; }
    .logo-text-wrap .logo-sub { font-size: 0.7rem; color: rgba(255,255,255,0.55); }
    nav { display: flex; align-items: center; gap: 20px; }
    nav a { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: white; }
    .btn-call { background: var(--gold); color: var(--g900) !important; padding: 8px 16px; border-radius: 6px; font-weight: 700 !important; font-size: 0.8rem !important; white-space: nowrap; }

    /* Hero */
    .hero { background: linear-gradient(135deg, var(--g900) 0%, var(--g800) 60%, var(--g700) 100%); color: white; padding: 72px 24px 60px; text-align: center; }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; background: rgba(240,192,64,0.15); border: 1px solid rgba(240,192,64,0.3); color: var(--gold2); font-size: 0.8rem; font-weight: 600; padding: 6px 14px; border-radius: 20px; margin-bottom: 20px; letter-spacing: 0.05em; text-transform: uppercase; }
    .hero h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
    .hero p { font-size: 1.05rem; color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto; }

    /* Content */
    .content { max-width: 860px; margin: 0 auto; padding: 60px 24px; }
    .section { margin-bottom: 56px; }
    .section h2 { font-size: 1.5rem; font-weight: 700; color: var(--g800); margin-bottom: 16px; }
    .section p { color: #444; margin-bottom: 14px; font-size: 0.975rem; }

    /* Disclosure box */
    .disclosure {
      background: #fff8e1;
      border: 2px solid var(--gold);
      border-radius: var(--radius);
      padding: 24px 28px;
      margin-bottom: 56px;
    }
    .disclosure-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gold); margin-bottom: 8px; }
    .disclosure p { color: #4a3800; font-size: 0.95rem; margin: 0; line-height: 1.6; }

    /* Steps */
    .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 24px; }
    .step { background: var(--g50); border: 1px solid var(--g100); border-radius: var(--radius); padding: 24px; }
    .step-num { width: 36px; height: 36px; background: var(--g800); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1rem; margin-bottom: 12px; }
    .step h3 { font-size: 1rem; font-weight: 700; color: var(--g800); margin-bottom: 6px; }
    .step p { color: var(--muted); font-size: 0.875rem; margin: 0; }

    /* Benefits grid */
    .benefits { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 24px; }
    .benefit { display: flex; align-items: flex-start; gap: 12px; }
    .benefit-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 2px; }
    .benefit h3 { font-size: 0.95rem; font-weight: 700; color: var(--g800); margin-bottom: 4px; }
    .benefit p { color: var(--muted); font-size: 0.85rem; margin: 0; }

    /* Services list */
    .services-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 10px; margin-top: 16px; }
    .service-tag { background: var(--g50); border: 1px solid var(--g100); border-radius: 8px; padding: 10px 14px; font-size: 0.85rem; font-weight: 600; color: var(--g800); }

    /* CTA */
    .cta-section { background: linear-gradient(135deg, var(--g900), var(--g700)); border-radius: 16px; padding: 48px 32px; text-align: center; color: white; margin-bottom: 0; }
    .cta-section h2 { font-size: 1.6rem; font-weight: 800; margin-bottom: 12px; }
    .cta-section p { color: rgba(255,255,255,0.75); margin-bottom: 28px; font-size: 0.975rem; }
    .btn-primary { display: inline-block; background: var(--gold); color: var(--g900); padding: 14px 32px; border-radius: 8px; font-weight: 700; font-size: 1rem; text-decoration: none; }
    .btn-primary:hover { background: var(--gold2); }

    /* Footer */
    footer { background: var(--g900); color: rgba(255,255,255,0.6); text-align: center; padding: 28px 24px; font-size: 0.8rem; }
    footer a { color: var(--gold2); text-decoration: none; font-weight: 600; margin: 0 8px; }
    .footer-links { margin: 10px 0; }
    .footer-links a { font-size: 0.8rem; }

    @media (max-width: 600px) {
      .steps { grid-template-columns: 1fr; }
      .benefits { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <svg width="32" height="32" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="19" cy="19" r="19" fill="#2d6b4e"/>
        <path d="M19 8C13 8 8 13 8 19s5 11 11 11c1.8 0 3.5-.5 5-1.3L19 24l-3-6 6-3 3 6-3 3.7C25.5 23 27 21 27 19c0-6-4-10.5-8-11z" fill="white"/>
        <path d="M19 8c.7 3 1.8 10-3 14.5" stroke="#d4a017" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
      <div class="logo-text-wrap">
        <span class="logo-name">Las Vegas Landscaping</span>
        <span class="logo-sub">Licensed • Insured</span>
      </div>
    </a>
    <nav>
      <a href="/">Home</a>
      <a href="/areas">Service Areas</a>
      <a href="tel:7025288324" class="btn-call">📞 (702) 528-8324</a>
    </nav>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <div class="hero-eyebrow">🌵 Free Contractor Matching</div>
  <h1>About Las Vegas Landscaping</h1>
  <p>We connect Las Vegas homeowners with local licensed landscaping contractors — completely free of charge.</p>
</section>

<div class="content">

  <!-- Disclosure -->
  <div class="disclosure">
    <div class="disclosure-label">⚠ Important Disclosure</div>
    <p><strong>Las Vegas Landscaping is a free lead generation service.</strong> We are not a landscaping contractor. When you submit a request through this website, your contact information and project details are shared with one or more local licensed landscaping contractors in the Las Vegas area, who will contact you by phone, text, or email to discuss your project and provide a quote.</p>
  </div>

  <!-- What we are -->
  <div class="section">
    <h2>What We Do</h2>
    <p>Las Vegas Landscaping is a free online service that helps Southern Nevada homeowners get in touch with qualified local landscaping contractors quickly and easily. We've connected hundreds of homeowners with licensed, insured contractors who specialize in xeriscape, grass removal, artificial turf, hardscape, irrigation, and more.</p>
    <p>We use AI technology to generate an instant estimate so you know what to expect before a contractor ever calls — giving you confidence going into your project.</p>
  </div>

  <!-- How it works -->
  <div class="section">
    <h2>How It Works</h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Submit Your Request</h3>
        <p>Fill out our quick form with your project details, property size, and contact information.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Get an AI Estimate</h3>
        <p>Our AI instantly generates a ballpark estimate so you can see expected pricing before anyone calls.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Contractor Contacts You</h3>
        <p>A local licensed landscaping contractor in your area reaches out to schedule a free on-site quote.</p>
      </div>
    </div>
  </div>

  <!-- Why use us -->
  <div class="section">
    <h2>Why Use Our Service</h2>
    <div class="benefits">
      <div class="benefit">
        <div class="benefit-icon">✅</div>
        <div>
          <h3>100% Free</h3>
          <p>There is no cost to submit a request or receive an estimate. The service is always free for homeowners.</p>
        </div>
      </div>
      <div class="benefit">
        <div class="benefit-icon">⚡</div>
        <div>
          <h3>Instant AI Estimate</h3>
          <p>Know the expected price range immediately — before talking to anyone.</p>
        </div>
      </div>
      <div class="benefit">
        <div class="benefit-icon">🛡️</div>
        <div>
          <h3>Licensed Contractors</h3>
          <p>We connect you with licensed, insured local contractors in your area.</p>
        </div>
      </div>
      <div class="benefit">
        <div class="benefit-icon">📍</div>
        <div>
          <h3>Serving All of Las Vegas</h3>
          <p>We cover every city and community across the Las Vegas Valley.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Services -->
  <div class="section">
    <h2>Services We Help With</h2>
    <div class="services-list">
      <div class="service-tag">🌿 Xeriscape</div>
      <div class="service-tag">🌱 Grass Removal</div>
      <div class="service-tag">🪨 Artificial Turf</div>
      <div class="service-tag">💧 Irrigation</div>
      <div class="service-tag">🏗️ Hardscape</div>
      <div class="service-tag">🪴 Desert Landscaping</div>
      <div class="service-tag">🌵 Drought-Tolerant Plants</div>
      <div class="service-tag">🧹 Yard Cleanup</div>
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-section">
    <h2>Get Your Free Estimate Today</h2>
    <p>Submit your project details and a local contractor will contact you to schedule a free on-site quote.</p>
    <a href="/" class="btn-primary">Request a Free Estimate →</a>
  </div>

</div>

<footer>
  <div>
    <a href="/">Home</a>
    <a href="/areas">Service Areas</a>
    <a href="/rebate-calculator">Rebate Calculator</a>
    <a href="tel:7025288324">(702) 528-8324</a>
  </div>
  <div class="footer-links">
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/privacy-policy">Privacy Policy</a>
    <a href="/terms">Terms of Service</a>
  </div>
  &copy; {new Date().getFullYear()} Las Vegas Landscaping — Licensed &bull; Bonded &bull; Insured &bull; Nevada AB356 Compliant
</footer>

</body>
</html>
