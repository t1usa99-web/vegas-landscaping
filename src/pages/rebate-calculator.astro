---
import { cities } from '../data/cities.js';
const pageTitle = 'SNWA Grass Removal Rebate Calculator Las Vegas 2026 | How Much Will You Get?';
const pageDesc = 'Calculate your exact SNWA rebate for removing grass in Las Vegas. Up to $7/sq ft available. See your rebate amount, water savings, and annual bill reduction instantly.';
const canonicalUrl = 'https://lasvegaslandscaping.homepropeople.com/rebate-calculator';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap&font-display=swap" rel="stylesheet" />

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does the SNWA pay for grass removal in 2026?", "acceptedAnswer": { "@type": "Answer", "text": "The SNWA pays $5 per square foot for the first 10,000 square feet of grass removed, and $2.50 per square foot after that. LVVWD customers receive an additional $2 per square foot, bringing the total to $7 per square foot for the first 10,000 sq ft." } },
      { "@type": "Question", "name": "Does the rebate apply to artificial turf replacement?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Artificial turf is one of the qualifying desert landscaping replacements. The grass must be replaced with water-efficient landscaping — artificial turf, decomposed granite, pavers, native plants, or xeriscape all qualify." } },
      { "@type": "Question", "name": "What is the AB356 deadline for Las Vegas?", "acceptedAnswer": { "@type": "Answer", "text": "Nevada Assembly Bill 356 requires that non-functional ornamental grass be removed from commercial, government, and HOA properties by December 31, 2026. Residential properties are also affected by water restriction ordinances." } },
      { "@type": "Question", "name": "Can I get the SNWA rebate and also hire a landscaper?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. You apply for the rebate through SNWA/LVVWD and then hire a licensed contractor to do the work. The rebate check comes from the water authority after the project is inspected and approved." } },
      { "@type": "Question", "name": "How long does the SNWA rebate process take?", "acceptedAnswer": { "@type": "Answer", "text": "The typical timeline is: apply online (same day), receive approval letter (1-2 weeks), complete the project, submit completion paperwork, receive inspection (1-3 weeks), receive rebate check (4-6 weeks after inspection)." } }
    ]
  })}</script>

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lasvegaslandscaping.homepropeople.com/" },
      { "@type": "ListItem", "position": 2, "name": "Rebate Calculator", "item": canonicalUrl }
    ]
  })}</script>

  <style>
    :root {
      --g900: #0f2a1e; --g800: #1a4731; --g700: #2d6b4e; --g600: #3d8c62;
      --g100: #e8f4ee; --g50: #f4faf6;
      --gold: #d4a017; --gold2: #f0c040;
      --text: #1a1a1a; --muted: #6b7280; --border: #e2e8f0;
      --shadow: 0 4px 20px rgba(0,0,0,0.08);
      --radius: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; color: var(--text); background: #fff; line-height: 1.6; }
    a { color: inherit; }

    /* ── Header ── */
    .site-header { background: var(--g900); padding: 0 24px; position: sticky; top: 0; z-index: 100; }
    .header-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 60px; gap: 16px; }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-text-wrap .logo-name { font-weight: 800; font-size: 1rem; color: white; display: block; }
    .logo-text-wrap .logo-sub { font-size: 0.7rem; color: rgba(255,255,255,0.55); }
    nav { display: flex; align-items: center; gap: 20px; }
    nav a { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: white; }
    .btn-call { background: var(--gold); color: var(--g900) !important; padding: 8px 16px; border-radius: 6px; font-weight: 700 !important; font-size: 0.8rem !important; white-space: nowrap; }
    .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; margin-left: auto; }
    .nav-toggle span { display: block; width: 22px; height: 2px; background: white; border-radius: 2px; }
    .mobile-nav { display: none; flex-direction: column; background: var(--g900); border-top: 1px solid rgba(255,255,255,0.1); }
    .mobile-nav.open { display: flex; }
    .mnav-link { color: rgba(255,255,255,0.85); text-decoration: none; padding: 14px 24px; font-weight: 500; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 0.9rem; }
    .mnav-link:hover { background: rgba(255,255,255,0.05); }
    .mnav-phone { color: var(--gold2); font-weight: 700; padding: 16px 24px; text-decoration: none; font-size: 1rem; }
    @media (max-width: 700px) { nav { display: none; } .nav-toggle { display: flex; } }

    /* ── Hero ── */
    .hero { background: linear-gradient(135deg, var(--g900) 0%, var(--g800) 60%, var(--g700) 100%); color: white; padding: 64px 24px 56px; text-align: center; }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; background: rgba(240,192,64,0.15); border: 1px solid rgba(240,192,64,0.3); color: var(--gold2); font-size: 0.8rem; font-weight: 600; padding: 6px 14px; border-radius: 20px; margin-bottom: 20px; letter-spacing: 0.05em; text-transform: uppercase; }
    .hero h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
    .hero h1 em { font-style: normal; color: var(--gold2); }
    .hero p { font-size: 1.1rem; color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto 32px; }
    .hero-stats { display: flex; justify-content: center; gap: 32px; flex-wrap: wrap; margin-top: 32px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.1); }
    .hero-stat { text-align: center; }
    .hero-stat-num { font-size: 1.5rem; font-weight: 800; color: var(--gold2); }
    .hero-stat-lbl { font-size: 0.75rem; color: rgba(255,255,255,0.6); margin-top: 2px; }

    /* ── Calculator ── */
    .calc-section { background: var(--g50); padding: 60px 24px; }
    .calc-wrap { max-width: 980px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
    @media (max-width: 700px) { .calc-wrap { grid-template-columns: 1fr; } }

    .calc-card { background: white; border-radius: var(--radius); padding: 32px; box-shadow: var(--shadow); border: 1px solid var(--border); }
    .calc-card h2 { font-size: 1.2rem; font-weight: 700; color: var(--g800); margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid var(--g100); }

    .field { margin-bottom: 24px; }
    .field label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
    .field-row { display: flex; gap: 12px; align-items: center; }
    .field input[type="number"], .field select {
      width: 100%; padding: 12px 14px; border: 1.5px solid var(--border); border-radius: 8px;
      font-size: 1rem; font-family: inherit; color: var(--text); background: white;
      transition: border-color 0.15s;
    }
    .field input[type="number"]:focus, .field select:focus { outline: none; border-color: var(--g600); }
    .field input[type="range"] { width: 100%; accent-color: var(--g700); margin-top: 6px; cursor: pointer; }
    .sqft-display { font-size: 1.5rem; font-weight: 800; color: var(--g800); min-width: 90px; text-align: right; white-space: nowrap; }
    .field-hint { font-size: 0.75rem; color: var(--muted); margin-top: 6px; }

    /* ── Results ── */
    .results-card { background: var(--g900); color: white; border-radius: var(--radius); padding: 32px; box-shadow: var(--shadow); }
    .results-card h2 { font-size: 1.2rem; font-weight: 700; color: rgba(255,255,255,0.7); margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,0.1); }

    .rebate-total { background: rgba(240,192,64,0.12); border: 1px solid rgba(240,192,64,0.3); border-radius: 10px; padding: 24px; text-align: center; margin-bottom: 24px; }
    .rebate-label { font-size: 0.75rem; font-weight: 600; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
    .rebate-amount { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; color: var(--gold2); line-height: 1; }
    .rebate-sub { font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-top: 6px; }

    .result-rows { display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }
    .result-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 14px; background: rgba(255,255,255,0.06); border-radius: 8px; }
    .result-row-label { font-size: 0.85rem; color: rgba(255,255,255,0.7); }
    .result-row-value { font-size: 1rem; font-weight: 700; color: white; }
    .result-row-value.green { color: #6ee7a0; }

    .results-cta { display: block; background: var(--gold); color: var(--g900); text-align: center; padding: 14px 20px; border-radius: 8px; font-weight: 800; font-size: 1rem; text-decoration: none; transition: background 0.15s; }
    .results-cta:hover { background: var(--gold2); }
    .results-note { font-size: 0.7rem; color: rgba(255,255,255,0.4); text-align: center; margin-top: 10px; }

    /* ── Info Section ── */
    .info-section { padding: 72px 24px; max-width: 1100px; margin: 0 auto; }
    .section-eyebrow { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--g600); margin-bottom: 10px; }
    .section-title { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; color: var(--g900); margin-bottom: 16px; }
    .section-desc { font-size: 1rem; color: var(--muted); max-width: 600px; margin-bottom: 48px; line-height: 1.7; }

    .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; margin-bottom: 72px; }
    .step-card { background: var(--g50); border: 1px solid var(--g100); border-radius: var(--radius); padding: 24px; position: relative; }
    .step-num { width: 36px; height: 36px; background: var(--g800); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.9rem; margin-bottom: 14px; }
    .step-title { font-size: 1rem; font-weight: 700; color: var(--g900); margin-bottom: 6px; }
    .step-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }

    /* ── Data Stats ── */
    .data-banner { background: var(--g800); color: white; border-radius: var(--radius); padding: 40px; margin-bottom: 72px; }
    .data-banner h3 { font-size: 1.3rem; font-weight: 800; margin-bottom: 8px; }
    .data-banner p { color: rgba(255,255,255,0.7); font-size: 0.9rem; margin-bottom: 28px; }
    .data-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 20px; }
    .data-stat { background: rgba(255,255,255,0.08); border-radius: 8px; padding: 16px; text-align: center; }
    .data-stat-num { font-size: 1.5rem; font-weight: 800; color: var(--gold2); }
    .data-stat-lbl { font-size: 0.75rem; color: rgba(255,255,255,0.6); margin-top: 4px; }

    /* ── Rates Table ── */
    .rates-table-wrap { overflow-x: auto; margin-bottom: 72px; }
    .rates-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .rates-table th { background: var(--g900); color: white; padding: 12px 16px; text-align: left; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .rates-table td { padding: 12px 16px; border-bottom: 1px solid var(--border); }
    .rates-table tr:nth-child(even) td { background: var(--g50); }
    .rates-table .rate-highlight { color: var(--g700); font-weight: 700; }

    /* ── FAQ ── */
    .faq-section { background: var(--g50); padding: 72px 24px; }
    .faq-wrap { max-width: 760px; margin: 0 auto; }
    .faq-item { background: white; border: 1px solid var(--border); border-radius: 10px; margin-bottom: 12px; overflow: hidden; }
    .faq-q { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 18px 22px; background: none; border: none; cursor: pointer; font-size: 1rem; font-weight: 600; color: var(--g900); text-align: left; font-family: inherit; transition: background 0.15s; }
    .faq-q:hover { background: var(--g50); }
    .faq-icon { font-size: 1.25rem; font-weight: 300; color: var(--g600); flex-shrink: 0; transition: transform 0.2s; }
    .faq-item.open .faq-q { background: var(--g50); }
    .faq-item.open .faq-icon { transform: rotate(45deg); }
    .faq-a { display: none; padding: 0 22px 18px; color: var(--muted); font-size: 0.95rem; line-height: 1.7; }
    .faq-item.open .faq-a { display: block; }

    /* ── City Links ── */
    .city-links-section { padding: 60px 24px; max-width: 1100px; margin: 0 auto; }
    .city-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
    .city-link { background: var(--g50); border: 1px solid var(--g100); border-radius: 8px; padding: 12px 16px; text-decoration: none; font-size: 0.85rem; font-weight: 600; color: var(--g800); text-align: center; transition: all 0.15s; }
    .city-link:hover { background: var(--g100); border-color: var(--g600); color: var(--g900); }

    /* ── Footer ── */
    footer { background: var(--g900); color: rgba(255,255,255,0.7); text-align: center; padding: 28px 24px; font-size: 0.8rem; }
    footer a { color: var(--gold2); text-decoration: none; font-weight: 700; margin: 0 8px; }
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <svg width="32" height="32" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="19" cy="19" r="19" fill="#2d6b4e"/>
        <path d="M19 8C13 8 8 13 8 19s5 11 11 11c1.8 0 3.5-.5 5-1.3L19 24l-3-6 6-3 3 6-3 3.7C25.5 23 27 21 27 19c0-6-4-10.5-8-11z" fill="white"/>
        <path d="M19 8c.7 3 1.8 10-3 14.5" stroke="#d4a017" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
      <div class="logo-text-wrap">
        <span class="logo-name">Las Vegas Landscaping</span>
        <span class="logo-sub">Licensed • Insured</span>
      </div>
    </a>
    <nav>
      <a href="/">Home</a>
      <a href="/areas">Service Areas</a>
      <a href="tel:7025288324" class="btn-call">📞 (702) 528-8324</a>
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <a href="/" class="mnav-link">Home</a>
    <a href="/areas" class="mnav-link">Service Areas</a>
    <a href="/rebate-calculator" class="mnav-link">💧 Rebate Calculator</a>
    <a href="tel:7025288324" class="mnav-phone">(702) 528-8324</a>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <div class="hero-eyebrow">💧 SNWA 2026 Rebate Program</div>
  <h1>How Much Will You Get for<br /><em>Removing Your Grass?</em></h1>
  <p>Up to $7 per square foot is available right now. Enter your square footage below and see your estimated rebate, water savings, and annual bill reduction instantly.</p>
  <div class="hero-stats">
    <div class="hero-stat">
      <div class="hero-stat-num">$345M+</div>
      <div class="hero-stat-lbl">Rebates paid since 1999</div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-num">250M sq ft</div>
      <div class="hero-stat-lbl">Grass converted</div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-num">203B gal</div>
      <div class="hero-stat-lbl">Water saved</div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-num">Dec 2026</div>
      <div class="hero-stat-lbl">AB356 deadline</div>
    </div>
  </div>
</section>

<!-- Calculator -->
<section class="calc-section">
  <div class="calc-wrap">

    <!-- Inputs -->
    <div class="calc-card">
      <h2>⚙️ Your Project Details</h2>

      <div class="field">
        <label for="sqft">Square Feet of Grass to Remove</label>
        <div class="field-row">
          <input type="range" id="sqft-slider" min="100" max="20000" value="1500" step="100" />
          <span class="sqft-display" id="sqft-display">1,500 sq ft</span>
        </div>
        <input type="number" id="sqft" value="1500" min="100" max="99999" placeholder="e.g. 1500" style="margin-top:10px" />
        <p class="field-hint">Average Las Vegas front yard: 800–2,000 sq ft. Backyard: 1,500–4,000 sq ft.</p>
      </div>

      <div class="field">
        <label for="provider">Water Provider</label>
        <select id="provider">
          <option value="lvvwd">LVVWD (Las Vegas Valley Water District) — $7/sq ft</option>
          <option value="snwa">SNWA only (Henderson, N. Las Vegas, other) — $5/sq ft</option>
        </select>
        <p class="field-hint">LVVWD serves most of Las Vegas. Henderson residents use City of Henderson Water + SNWA.</p>
      </div>

      <div class="field">
        <label for="trees">Desert Trees to Add (optional)</label>
        <input type="number" id="trees" value="0" min="0" max="100" placeholder="0" />
        <p class="field-hint">SNWA pays $100 per qualifying desert tree added during the project.</p>
      </div>
    </div>

    <!-- Results -->
    <div class="results-card">
      <h2>Your Estimated Rebate</h2>

      <div class="rebate-total">
        <div class="rebate-label">Total Rebate Estimate</div>
        <div class="rebate-amount" id="result-total">$10,500</div>
        <div class="rebate-sub" id="result-breakdown">$10,500 grass removal + $0 tree bonus</div>
      </div>

      <div class="result-rows">
        <div class="result-row">
          <span class="result-row-label">💧 Water Saved Per Year</span>
          <span class="result-row-value green" id="result-gallons">82,500 gal</span>
        </div>
        <div class="result-row">
          <span class="result-row-label">💵 Annual Water Bill Savings</span>
          <span class="result-row-value green" id="result-savings">~$248/yr</span>
        </div>
        <div class="result-row">
          <span class="result-row-label">📐 Sq Ft Being Converted</span>
          <span class="result-row-value" id="result-sqft">1,500 sq ft</span>
        </div>
        <div class="result-row">
          <span class="result-row-label">📅 AB356 Deadline</span>
          <span class="result-row-value" style="color:#fca5a5">Dec 31, 2026</span>
        </div>
      </div>

      <a href="tel:7025288324" class="results-cta">📞 Get a Free Removal Quote — (702) 528-8324</a>
      <p class="results-note">Estimates based on published SNWA/LVVWD rates. Actual rebate subject to program availability and inspection approval. Not a guarantee of rebate amount.</p>
    </div>

  </div>
</section>

<!-- How It Works -->
<section class="info-section">
  <div class="section-eyebrow">Step by Step</div>
  <h2 class="section-title">How the SNWA Rebate Process Works</h2>
  <p class="section-desc">Getting your rebate is straightforward — but you must apply before starting the project. Here's the full process.</p>

  <div class="steps-grid">
    <div class="step-card">
      <div class="step-num">1</div>
      <div class="step-title">Apply Online First</div>
      <div class="step-desc">Submit your application at snwa.com before any work begins. Pre-approval is required — work started before approval is not eligible.</div>
    </div>
    <div class="step-card">
      <div class="step-num">2</div>
      <div class="step-title">Receive Approval Letter</div>
      <div class="step-desc">SNWA reviews your application and sends an approval letter with your locked-in rebate amount. Usually takes 1–2 weeks.</div>
    </div>
    <div class="step-card">
      <div class="step-num">3</div>
      <div class="step-title">Complete the Project</div>
      <div class="step-desc">Remove the grass and install qualifying desert landscaping — artificial turf, xeriscape, DG, pavers, or native plants. We handle this for you.</div>
    </div>
    <div class="step-card">
      <div class="step-num">4</div>
      <div class="step-title">Submit Completion Docs</div>
      <div class="step-desc">Submit your before/after photos and completion paperwork. SNWA schedules an on-site inspection to verify the work.</div>
    </div>
    <div class="step-card">
      <div class="step-num">5</div>
      <div class="step-title">Receive Your Check</div>
      <div class="step-desc">After inspection approval, SNWA mails your rebate check. Timeline is typically 4–6 weeks post-inspection.</div>
    </div>
  </div>

  <!-- Program Stats -->
  <div class="data-banner">
    <h3>The Numbers Behind the Program</h3>
    <p>Source: Southern Nevada Water Authority — Water Smart Landscapes program data</p>
    <div class="data-stats">
      <div class="data-stat">
        <div class="data-stat-num">55 gal</div>
        <div class="data-stat-lbl">Saved per sq ft per year</div>
      </div>
      <div class="data-stat">
        <div class="data-stat-num">55%</div>
        <div class="data-stat-lbl">Per capita water reduction since 2002</div>
      </div>
      <div class="data-stat">
        <div class="data-stat-num">49%</div>
        <div class="data-stat-lbl">Population growth in same period</div>
      </div>
      <div class="data-stat">
        <div class="data-stat-num">$345M</div>
        <div class="data-stat-lbl">Total rebates paid since 1999</div>
      </div>
      <div class="data-stat">
        <div class="data-stat-num">90M kWh</div>
