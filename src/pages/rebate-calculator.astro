<script is:inline>
  // ── Mobile Nav ──────────────────────────────────────────────────────
  (function() {
    const toggle = document.getElementById('nav-toggle');
    const nav = document.getElementById('mobile-nav');
    if (!toggle || !nav) return;
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      nav.setAttribute('aria-hidden', open ? 'false' : 'true');
    });
    nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      nav.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      nav.setAttribute('aria-hidden', 'true');
    }));
  })();

  // ── Rebate calculation logic ────────────────────────────────────────
  const SNWA_T1 = 5.00, SNWA_T2 = 2.50;
  const LVVWD_T1 = 2.00, LVVWD_T2 = 1.50;
  const TREE_BONUS = 100;
  const GALLONS_PER_SQFT = 55;
  const WATER_COST_PER_GALLON = 0.003; // ~$3/1,000 gal avg Las Vegas rate
  const TIER_BREAK = 10000;

  function calcRebate(sqft, provider, trees) {
    const addl = provider === 'lvvwd' ? { t1: LVVWD_T1, t2: LVVWD_T2 } : { t1: 0, t2: 0 };
    const rateT1 = SNWA_T1 + addl.t1;
    const rateT2 = SNWA_T2 + addl.t2;
    const tier1 = Math.min(sqft, TIER_BREAK);
    const tier2 = Math.max(0, sqft - TIER_BREAK);
    const grassRebate = (tier1 * rateT1) + (tier2 * rateT2);
    const treeRebate = (trees || 0) * TREE_BONUS;
    return { grassRebate, treeRebate, total: grassRebate + treeRebate };
  }

  function fmt(n) { return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }); }
  function fmtNum(n) { return n.toLocaleString('en-US', { maximumFractionDigits: 0 }); }

  function update() {
    const sqft = Math.max(0, parseInt(document.getElementById('sqft').value) || 0);
    const provider = document.getElementById('provider').value;
    const trees = Math.max(0, parseInt(document.getElementById('trees').value) || 0);

    // Sync slider
    const slider = document.getElementById('sqft-slider');
    slider.value = Math.min(sqft, 20000);
    document.getElementById('sqft-display').textContent = fmtNum(sqft) + ' sq ft';

    const { grassRebate, treeRebate, total } = calcRebate(sqft, provider, trees);
    const gallons = sqft * GALLONS_PER_SQFT;
    const billSavings = gallons * WATER_COST_PER_GALLON;

    document.getElementById('result-total').textContent = fmt(total);
    document.getElementById('result-breakdown').textContent =
      fmt(grassRebate) + ' grass removal' + (treeRebate > 0 ? ' + ' + fmt(treeRebate) + ' tree bonus' : '');
    document.getElementById('result-gallons').textContent = fmtNum(gallons) + ' gal';
    document.getElementById('result-savings').textContent = '~' + fmt(billSavings) + '/yr';
    document.getElementById('result-sqft').textContent = fmtNum(sqft) + ' sq ft';
  }

  // Slider syncs to number input
  document.getElementById('sqft-slider').addEventListener('input', function() {
    document.getElementById('sqft').value = this.value;
    update();
  });

  document.getElementById('sqft').addEventListener('input', update);
  document.getElementById('provider').addEventListener('change', update);
  document.getElementById('trees').addEventListener('input', update);

  update();

  // ── FAQ accordion ───────────────────────────────────────────────────
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-q').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) { item.classList.add('open'); btn.setAttribute('aria-expanded', 'true'); }
    });
  });
</script>

</body>
</html>
