<script is:inline>
  const SNWA_T1=5,SNWA_T2=2.5,LVVWD_T1=2,LVVWD_T2=1.5,TREE_BONUS=100,GAL=55,RATE=0.003,TIER=10000;
  function calcRebate(sqft,provider,trees){
    const a=provider==='lvvwd'?{t1:LVVWD_T1,t2:LVVWD_T2}:{t1:0,t2:0};
    const r1=SNWA_T1+a.t1,r2=SNWA_T2+a.t2;
    const t1=Math.min(sqft,TIER),t2=Math.max(0,sqft-TIER);
    const g=(t1*r1)+(t2*r2),tr=(trees||0)*TREE_BONUS;
    return{g,tr,total:g+tr};
  }
  function fmt(n){return n.toLocaleString('es-MX',{style:'currency',currency:'USD',maximumFractionDigits:0})}
  function fmtN(n){return n.toLocaleString('es-MX',{maximumFractionDigits:0})}
  function update(){
    const sqft=Math.max(0,parseInt(document.getElementById('sqft').value)||0);
    const provider=document.getElementById('provider').value;
    const trees=Math.max(0,parseInt(document.getElementById('trees').value)||0);
    document.getElementById('sqft-slider').value=Math.min(sqft,20000);
    document.getElementById('sqft-display').textContent=fmtN(sqft)+' pies²';
    const{g,tr,total}=calcRebate(sqft,provider,trees);
    const gallons=sqft*GAL,bill=gallons*RATE;
    document.getElementById('result-total').textContent=fmt(total);
    document.getElementById('result-breakdown').textContent=fmt(g)+' remoción de pasto'+(tr>0?' + '+fmt(tr)+' bono árboles':'');
    document.getElementById('result-gallons').textContent=fmtN(gallons)+' gal';
    document.getElementById('result-savings').textContent='~'+fmt(bill)+'/año';
    document.getElementById('result-sqft').textContent=fmtN(sqft)+' pies²';
  }
  document.getElementById('sqft-slider').addEventListener('input',function(){document.getElementById('sqft').value=this.value;update();});
  document.getElementById('sqft').addEventListener('input',update);
  document.getElementById('provider').addEventListener('change',update);
  document.getElementById('trees').addEventListener('input',update);
  update();
  document.querySelectorAll('.faq-q').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const item=btn.closest('.faq-item'),isOpen=item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i=>{i.classList.remove('open');i.querySelector('.faq-q').setAttribute('aria-expanded','false');});
      if(!isOpen){item.classList.add('open');btn.setAttribute('aria-expanded','true');}
    });
  });
</script>
</body>
