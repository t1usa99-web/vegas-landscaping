---
import { cities } from '../../data/cities.js';
const SITE = 'https://lasvegaslandscaping.homepropeople.com';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Calculadora de Rebaja SNWA Las Vegas 2026 | ¿Cuánto Te Pagan por Quitar el Pasto?</title>
  <meta name="description" content="Calcula tu rebaja exacta del SNWA por quitar el pasto en Las Vegas. Hasta $7 por pie cuadrado disponible ahora. Ve tu rebaja, ahorro de agua y reducción de factura al instante." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`${SITE}/es/calculadora-rebate`} />
  <link rel="alternate" hreflang="en" href={`${SITE}/rebate-calculator`} />
  <link rel="alternate" hreflang="es" href={`${SITE}/es/calculadora-rebate`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE}/rebate-calculator`} />
  <meta property="og:url" content={`${SITE}/es/calculadora-rebate`} />
  <meta property="og:title" content="Calculadora de Rebaja SNWA Las Vegas 2026" />
  <meta property="og:description" content="Hasta $7 por pie cuadrado disponible. Calcula tu rebaja por remoción de pasto en segundos." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap&font-display=swap" rel="stylesheet" />
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuánto paga el SNWA por remoción de pasto en 2026?", "acceptedAnswer": { "@type": "Answer", "text": "El SNWA paga $5 por pie cuadrado por los primeros 10,000 pies cuadrados removidos y $2.50/pie cuadrado después. Los clientes del LVVWD reciben $2 adicionales por pie cuadrado, llevando el total a $7 por pie cuadrado (hasta 10,000 pies cuadrados)." } },
      { "@type": "Question", "name": "¿La rebaja aplica para reemplazo con césped artificial?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. El césped artificial es uno de los reemplazos de paisajismo desértico calificados. El pasto debe reemplazarse con paisajismo eficiente en agua — césped artificial, grava decorativa, adoquines, plantas nativas o xeriscape todos califican." } },
      { "@type": "Question", "name": "¿Cuál es la fecha límite de la Ley AB356 de Las Vegas?", "acceptedAnswer": { "@type": "Answer", "text": "La Ley AB356 de Nevada requiere que el pasto ornamental no funcional sea removido de propiedades comerciales, gubernamentales y administradas por HOA antes del 31 de diciembre de 2026." } },
      { "@type": "Question", "name": "¿Puedo obtener la rebaja del SNWA y también contratar un paisajista?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Solicitas la rebaja a través del SNWA/LVVWD y luego contratas a un contratista con licencia para hacer el trabajo. El cheque de rebaja llega de la autoridad de agua después de que el proyecto sea inspeccionado y aprobado." } }
    ]
  })}</script>
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${SITE}/es/` },
      { "@type": "ListItem", "position": 2, "name": "Calculadora de Rebaja", "item": `${SITE}/es/calculadora-rebate` }
    ]
  })}</script>
  <style>
    :root{--g900:#0f2a1e;--g800:#1a4731;--g700:#2d6b4e;--g600:#3d8c62;--g100:#e8f4ee;--g50:#f4faf6;--gold:#d4a017;--gold2:#f0c040;--text:#1a1a1a;--muted:#6b7280;--border:#e2e8f0;--shadow:0 4px 20px rgba(0,0,0,0.08);--radius:12px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;color:var(--text);background:#fff;line-height:1.6}
    a{color:inherit;text-decoration:none}
    .site-header{background:var(--g900);padding:0 24px;position:sticky;top:0;z-index:100}
    .header-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:60px;gap:16px}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-name{font-weight:800;font-size:1rem;color:white;display:block}
    .logo-sub{font-size:0.7rem;color:rgba(255,255,255,0.55)}
    nav{display:flex;align-items:center;gap:16px}
    nav a{color:rgba(255,255,255,0.75);font-size:0.875rem;font-weight:500}
    nav a:hover{color:white}
    .btn-call{background:var(--gold);color:var(--g900)!important;padding:8px 16px;border-radius:6px;font-weight:700!important;font-size:0.8rem!important;white-space:nowrap}
    .lang-link{color:rgba(255,255,255,0.6);font-size:0.8rem;border:1px solid rgba(255,255,255,0.2);padding:4px 10px;border-radius:5px}
    .hero{background:linear-gradient(135deg,var(--g900) 0%,var(--g800) 60%,var(--g700) 100%);color:white;padding:64px 24px 56px;text-align:center}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(240,192,64,0.15);border:1px solid rgba(240,192,64,0.3);color:var(--gold2);font-size:0.8rem;font-weight:600;padding:6px 14px;border-radius:20px;margin-bottom:20px;text-transform:uppercase;letter-spacing:0.05em}
    .hero h1{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;line-height:1.2;margin-bottom:16px}
    .hero h1 em{font-style:normal;color:var(--gold2)}
    .hero>div>p{font-size:1.1rem;color:rgba(255,255,255,0.8);max-width:600px;margin:0 auto 32px}
    .hero-stats{display:flex;justify-content:center;gap:32px;flex-wrap:wrap;margin-top:32px;padding-top:32px;border-top:1px solid rgba(255,255,255,0.1)}
    .hero-stat-num{font-size:1.5rem;font-weight:800;color:var(--gold2)}
    .hero-stat-lbl{font-size:0.75rem;color:rgba(255,255,255,0.6);margin-top:2px}
    .calc-section{background:var(--g50);padding:60px 24px}
    .calc-wrap{max-width:980px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start}
    @media(max-width:700px){.calc-wrap{grid-template-columns:1fr}}
    .calc-card{background:white;border-radius:var(--radius);padding:32px;box-shadow:var(--shadow);border:1px solid var(--border)}
    .calc-card h2{font-size:1.2rem;font-weight:700;color:var(--g800);margin-bottom:24px;padding-bottom:16px;border-bottom:2px solid var(--g100)}
    .field{margin-bottom:24px}
    .field label{display:block;font-size:0.8rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px}
    .field-row{display:flex;gap:12px;align-items:center}
    .field input[type="number"],.field select{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:1rem;font-family:inherit;color:var(--text);background:white;transition:border-color 0.15s}
    .field input[type="number"]:focus,.field select:focus{outline:none;border-color:var(--g600)}
    .field input[type="range"]{width:100%;accent-color:var(--g700);margin-top:6px;cursor:pointer}
    .sqft-display{font-size:1.5rem;font-weight:800;color:var(--g800);min-width:100px;text-align:right;white-space:nowrap}
    .field-hint{font-size:0.75rem;color:var(--muted);margin-top:6px}
    .results-card{background:var(--g900);color:white;border-radius:var(--radius);padding:32px;box-shadow:var(--shadow)}
    .results-card h2{font-size:1.2rem;font-weight:700;color:rgba(255,255,255,0.7);margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,0.1)}
    .rebate-total{background:rgba(240,192,64,0.12);border:1px solid rgba(240,192,64,0.3);border-radius:10px;padding:24px;text-align:center;margin-bottom:24px}
    .rebate-label{font-size:0.75rem;font-weight:600;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px}
    .rebate-amount{font-size:clamp(2rem,5vw,3rem);font-weight:800;color:var(--gold2);line-height:1}
    .rebate-sub{font-size:0.8rem;color:rgba(255,255,255,0.5);margin-top:6px}
    .result-rows{display:flex;flex-direction:column;gap:14px;margin-bottom:28px}
    .result-row{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;background:rgba(255,255,255,0.06);border-radius:8px}
    .result-row-label{font-size:0.85rem;color:rgba(255,255,255,0.7)}
    .result-row-value{font-size:1rem;font-weight:700;color:white}
    .result-row-value.green{color:#6ee7a0}
    .results-cta{display:block;background:var(--gold);color:var(--g900);text-align:center;padding:14px 20px;border-radius:8px;font-weight:800;font-size:1rem;transition:background 0.15s}
    .results-cta:hover{background:var(--gold2)}
    .results-note{font-size:0.7rem;color:rgba(255,255,255,0.4);text-align:center;margin-top:10px}
    .info-section{padding:72px 24px;max-width:1100px;margin:0 auto}
    .section-eyebrow{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--g600);margin-bottom:10px}
    .section-title{font-size:clamp(1.4rem,3vw,2rem);font-weight:800;color:var(--g900);margin-bottom:16px}
    .section-desc{font-size:1rem;color:var(--muted);max-width:600px;margin-bottom:48px;line-height:1.7}
    .steps-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;margin-bottom:72px}
    .step-card{background:var(--g50);border:1px solid var(--g100);border-radius:var(--radius);padding:24px}
    .step-num{width:36px;height:36px;background:var(--g800);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;margin-bottom:14px}
    .step-title{font-size:1rem;font-weight:700;color:var(--g900);margin-bottom:6px}
    .step-desc{font-size:0.85rem;color:var(--muted);line-height:1.6}
    .data-banner{background:var(--g800);color:white;border-radius:var(--radius);padding:40px;margin-bottom:72px}
    .data-banner h3{font-size:1.3rem;font-weight:800;margin-bottom:8px}
    .data-banner p{color:rgba(255,255,255,0.7);font-size:0.9rem;margin-bottom:28px}
    .data-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:20px}
    .data-stat{background:rgba(255,255,255,0.08);border-radius:8px;padding:16px;text-align:center}
    .data-stat-num{font-size:1.5rem;font-weight:800;color:var(--gold2)}
    .data-stat-lbl{font-size:0.75rem;color:rgba(255,255,255,0.6);margin-top:4px}
    .rates-table-wrap{overflow-x:auto;margin-bottom:72px}
    .rates-table{width:100%;border-collapse:collapse;font-size:0.9rem}
    .rates-table th{background:var(--g900);color:white;padding:12px 16px;text-align:left;font-weight:600;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.05em}
    .rates-table td{padding:12px 16px;border-bottom:1px solid var(--border)}
    .rates-table tr:nth-child(even) td{background:var(--g50)}
    .rates-table .rate-highlight{color:var(--g700);font-weight:700}
    .faq-section{background:var(--g50);padding:72px 24px}
    .faq-wrap{max-width:760px;margin:0 auto}
    .faq-item{background:white;border:1px solid var(--border);border-radius:10px;margin-bottom:12px;overflow:hidden}
    .faq-q{width:100%;display:flex;justify-content:space-between;align-items:center;padding:18px 22px;background:none;border:none;cursor:pointer;font-size:1rem;font-weight:600;color:var(--g900);text-align:left;font-family:inherit;transition:background 0.15s}
    .faq-q:hover{background:var(--g50)}
    .faq-icon{font-size:1.25rem;font-weight:300;color:var(--g600);flex-shrink:0;transition:transform 0.2s}
    .faq-item.open .faq-q{background:var(--g50)}
    .faq-item.open .faq-icon{transform:rotate(45deg)}
    .faq-a{display:none;padding:0 22px 18px;color:var(--muted);font-size:0.95rem;line-height:1.7}
    .faq-item.open .faq-a{display:block}
    .city-links-section{padding:60px 24px;max-width:1100px;margin:0 auto}
    .city-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px}
    .city-link{background:var(--g50);border:1px solid var(--g100);border-radius:8px;padding:12px 16px;font-size:0.85rem;font-weight:600;color:var(--g800);text-align:center;transition:all 0.15s}
    .city-link:hover{background:var(--g100);border-color:var(--g600)}
    footer{background:var(--g900);color:rgba(255,255,255,0.7);text-align:center;padding:28px 24px;font-size:0.8rem}
    footer a{color:var(--gold2);font-weight:700;margin:0 8px}
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <a href="/es/" class="logo">
      <svg width="32" height="32" viewBox="0 0 38 38" fill="none" aria-hidden="true">
        <circle cx="19" cy="19" r="19" fill="#2d6b4e"/>
        <path d="M19 8C13 8 8 13 8 19s5 11 11 11c1.8 0 3.5-.5 5-1.3L19 24l-3-6 6-3 3 6-3 3.7C25.5 23 27 21 27 19c0-6-4-10.5-8-11z" fill="white"/>
        <path d="M19 8c.7 3 1.8 10-3 14.5" stroke="#d4a017" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
      <div>
        <span class="logo-name">Las Vegas Landscaping</span>
        <span class="logo-sub">Con Licencia • Asegurado</span>
      </div>
    </a>
    <nav>
      <a href="/es/">Inicio</a>
      <a href="/es/areas">Áreas de Servicio</a>
      <a href="/rebate-calculator" class="lang-link">🇺🇸 English</a>
      <a href="tel:7025288324" class="btn-call">📞 (702) 528-8324</a>
    </nav>
  </div>
</header>

<section class="hero">
  <div style="max-width:1100px;margin:0 auto">
    <div class="hero-eyebrow">💧 Programa de Rebaja SNWA 2026</div>
    <h1>¿Cuánto Te Pagarán por<br /><em>Quitar Tu Pasto?</em></h1>
    <p>Hay hasta $7 por pie cuadrado disponible ahora mismo. Ingresa tus pies cuadrados y ve tu rebaja estimada, ahorro de agua y reducción de factura al instante.</p>
    <div class="hero-stats">
      <div class="hero-stat"><div class="hero-stat-num">$345M+</div><div class="hero-stat-lbl">Rebajas pagadas desde 1999</div></div>
      <div class="hero-stat"><div class="hero-stat-num">250M pies²</div><div class="hero-stat-lbl">Pasto convertido</div></div>
      <div class="hero-stat"><div class="hero-stat-num">203B gal</div><div class="hero-stat-lbl">Agua ahorrada</div></div>
      <div class="hero-stat"><div class="hero-stat-num">Dic 2026</div><div class="hero-stat-lbl">Fecha límite AB356</div></div>
    </div>
  </div>
</section>

<section class="calc-section">
  <div class="calc-wrap">
    <div class="calc-card">
      <h2>⚙️ Detalles de Tu Proyecto</h2>
      <div class="field">
        <label for="sqft">Pies Cuadrados de Pasto a Remover</label>
        <div class="field-row">
          <input type="range" id="sqft-slider" min="100" max="20000" value="1500" step="100" />
          <span class="sqft-display" id="sqft-display">1,500 pies²</span>
        </div>
        <input type="number" id="sqft" value="1500" min="100" max="99999" placeholder="ej. 1500" style="margin-top:10px" />
        <p class="field-hint">Jardín delantero promedio en Las Vegas: 800–2,000 pies². Jardín trasero: 1,500–4,000 pies².</p>
      </div>
      <div class="field">
        <label for="provider">Proveedor de Agua</label>
        <select id="provider">
          <option value="lvvwd">LVVWD (Distrito de Agua del Valle de Las Vegas) — $7/pie²</option>
          <option value="snwa">Solo SNWA (Henderson, N. Las Vegas, otros) — $5/pie²</option>
        </select>
        <p class="field-hint">LVVWD sirve la mayor parte de Las Vegas. Los residentes de Henderson usan el Agua de la Ciudad de Henderson + SNWA.</p>
      </div>
      <div class="field">
        <label for="trees">Árboles Desérticos a Agregar (opcional)</label>
        <input type="number" id="trees" value="0" min="0" max="100" placeholder="0" />
        <p class="field-hint">El SNWA paga $100 por cada árbol desértico calificado agregado durante el proyecto.</p>
      </div>
    </div>

    <div class="results-card">
      <h2>Tu Rebaja Estimada</h2>
      <div class="rebate-total">
        <div class="rebate-label">Total Estimado de Rebaja</div>
        <div class="rebate-amount" id="result-total">$10,500</div>
        <div class="rebate-sub" id="result-breakdown">$10,500 remoción de pasto + $0 bono de árboles</div>
      </div>
      <div class="result-rows">
        <div class="result-row">
          <span class="result-row-label">💧 Agua Ahorrada por Año</span>
          <span class="result-row-value green" id="result-gallons">82,500 gal</span>
        </div>
        <div class="result-row">
          <span class="result-row-label">💵 Ahorro Anual en Factura de Agua</span>
          <span class="result-row-value green" id="result-savings">~$248/año</span>
        </div>
        <div class="result-row">
          <span class="result-row-label">📐 Pies² a Convertir</span>
          <span class="result-row-value" id="result-sqft">1,500 pies²</span>
        </div>
        <div class="result-row">
          <span class="result-row-label">📅 Fecha Límite AB356</span>
          <span class="result-row-value" style="color:#fca5a5">31 Dic, 2026</span>
        </div>
      </div>
      <a href="tel:7025288324" class="results-cta">📞 Cotización Gratis — (702) 528-8324</a>
      <p class="results-note">Estimados basados en tarifas publicadas del SNWA/LVVWD. La rebaja real está sujeta a disponibilidad del programa y aprobación de inspección. No es una garantía del monto de rebaja.</p>
    </div>
  </div>
</section>

<section class="info-section">
  <div class="section-eyebrow">Paso a Paso</div>
  <h2 class="section-title">Cómo Funciona el Proceso de Rebaja del SNWA</h2>
  <p class="section-desc">Obtener tu rebaja es sencillo — pero debes solicitar antes de comenzar el proyecto. Aquí está el proceso completo.</p>
  <div class="steps-grid">
    <div class="step-card"><div class="step-num">1</div><div class="step-title">Solicita en Línea Primero</div><div class="step-desc">Envía tu solicitud en snwa.com antes de iniciar cualquier trabajo. La pre-aprobación es requerida — los trabajos iniciados sin aprobación no son elegibles.</div></div>
    <div class="step-card"><div class="step-num">2</div><div class="step-title">Recibe Carta de Aprobación</div><div class="step-desc">El SNWA revisa tu solicitud y envía una carta de aprobación con el monto de rebaja confirmado. Generalmente tarda 1–2 semanas.</div></div>
    <div class="step-card"><div class="step-num">3</div><div class="step-title">Completa el Proyecto</div><div class="step-desc">Remueve el pasto e instala paisajismo desértico calificado — césped artificial, xeriscape, grava, adoquines o plantas nativas. Nosotros hacemos todo esto.</div></div>
    <div class="step-card"><div class="step-num">4</div><div class="step-title">Envía Documentos de Finalización</div><div class="step-desc">Envía fotos del antes/después y el papeleo de finalización. El SNWA programa una inspección en sitio para verificar el trabajo.</div></div>
    <div class="step-card"><div class="step-num">5</div><div class="step-title">Recibe Tu Cheque</div><div class="step-desc">Después de la aprobación de la inspección, el SNWA envía tu cheque de rebaja por correo. El plazo es típicamente 4–6 semanas después de la inspección.</div></div>
  </div>

  <div class="data-banner">
    <h3>Los Números Detrás del Programa</h3>
    <p>Fuente: Autoridad de Agua del Sur de Nevada — datos del programa Water Smart Landscapes</p>
    <div class="data-stats">
      <div class="data-stat"><div class="data-stat-num">55 gal</div><div class="data-stat-lbl">Ahorrados por pie² por año</div></div>
      <div class="data-stat"><div class="data-stat-num">55%</div><div class="data-stat-lbl">Reducción de agua per cápita desde 2002</div></div>
      <div class="data-stat"><div class="data-stat-num">49%</div><div class="data-stat-lbl">Crecimiento poblacional en el mismo período</div></div>
      <div class="data-stat"><div class="data-stat-num">$345M</div><div class="data-stat-lbl">Total de rebajas pagadas desde 1999</div></div>
      <div class="data-stat"><div class="data-stat-num">90M kWh</div><div class="data-stat-lbl">Energía ahorrada anualmente</div></div>
      <div class="data-stat"><div class="data-stat-num">1%</div><div class="data-stat-lbl">Aumento promedio en valor de propiedad</div></div>
    </div>
  </div>

  <div class="section-eyebrow">Tarifas Actuales</div>
  <h2 class="section-title" style="margin-bottom:24px">Desglose de Tarifas de Rebaja 2026</h2>
  <div class="rates-table-wrap">
    <table class="rates-table">
      <thead>
        <tr><th>Proveedor de Agua</th><th>Primeros 10,000 pies²</th><th>Después de 10,000 pies²</th><th>Bono por Árbol</th></tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Clientes LVVWD</strong><br /><small style="color:#6b7280">SNWA $5 + LVVWD $2</small></td>
          <td class="rate-highlight">$7.00 / pie²</td>
          <td class="rate-highlight">$4.50 / pie²</td>
          <td class="rate-highlight">$100 / árbol</td>
        </tr>
        <tr>
          <td><strong>Otros Miembros SNWA</strong><br /><small style="color:#6b7280">Henderson, N. Las Vegas, Boulder City</small></td>
