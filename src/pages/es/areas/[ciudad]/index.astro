---
import { cities, getCity, getNearbyCities } from '../../../../data/cities.js';
import { services } from '../../../../data/services.js';
import { serviceTranslations, getCityTranslation } from '../../../../data/translations-es.js';

const { ciudad } = Astro.params;
const city = getCity(ciudad);
if (!city) return Astro.redirect('/es/areas');

const nearbyCities = getNearbyCities(ciudad);
const cityTrans = getCityTranslation(ciudad);
const SITE = 'https://lasvegaslandscaping.homepropeople.com';

const pageTitle = `Servicios de Paisajismo en ${city.name}, NV | Las Vegas Landscaping`;
const pageDesc = `Paisajismo profesional en ${city.name}, Nevada. Xeriscape, instalación de patio, césped artificial, riego por goteo, palmeras y más. Con licencia, asegurado y cumple con AB356.`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Las Vegas Landscaping",
  "description": pageDesc,
  "areaServed": city.name,
  "telephone": "(702) 528-8324",
  "address": { "@type": "PostalAddress", "addressLocality": city.name, "addressRegion": "NV", "addressCountry": "US" },
  "inLanguage": "es",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": `Servicios de Paisajismo en ${city.name}`,
    "itemListElement": services.map((s, i) => ({
      "@type": "Offer", "position": i + 1,
      "name": serviceTranslations[s.slug]?.nameEs || s.name,
      "description": serviceTranslations[s.slug]?.metaDescEs || s.metaDesc
    }))
  }
};
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${SITE}/es/` },
    { "@type": "ListItem", "position": 2, "name": "Áreas de Servicio", "item": `${SITE}/es/areas` },
    { "@type": "ListItem", "position": 3, "name": city.name, "item": `${SITE}/es/areas/${ciudad}` }
  ]
};
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`${SITE}/es/areas/${ciudad}`} />
  <link rel="alternate" hreflang="en" href={`${SITE}/areas/${ciudad}`} />
  <link rel="alternate" hreflang="es" href={`${SITE}/es/areas/${ciudad}`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE}/areas/${ciudad}`} />
  <meta property="og:url" content={`${SITE}/es/areas/${ciudad}`} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap&font-display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <style>
    :root{--g900:#0f2a1e;--g800:#1a4731;--g700:#2d6b4e;--g600:#3d8c62;--g100:#e8f4ee;--g50:#f4faf6;--gold:#d4a017;--gold2:#f0c040;--text:#1a1a1a;--muted:#6b7280;--border:#e2e8f0;--shadow:0 4px 20px rgba(0,0,0,0.08);--radius:12px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;color:var(--text);background:#fff;line-height:1.6}
    a{color:inherit;text-decoration:none}
    .site-header{background:var(--g900);padding:0 24px;position:sticky;top:0;z-index:100}
    .header-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:60px;gap:16px}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-name{font-weight:800;font-size:1rem;color:white;display:block}
    .logo-sub{font-size:0.7rem;color:rgba(255,255,255,0.55)}
    nav{display:flex;align-items:center;gap:14px}
    nav a{color:rgba(255,255,255,0.75);font-size:0.875rem;font-weight:500}
    nav a:hover{color:white}
    .btn-call{background:var(--gold);color:var(--g900)!important;padding:8px 16px;border-radius:6px;font-weight:700!important;font-size:0.8rem!important;white-space:nowrap}
    .lang-link{color:rgba(255,255,255,0.6);font-size:0.8rem;border:1px solid rgba(255,255,255,0.2);padding:4px 10px;border-radius:5px}
    .page-hero{background:linear-gradient(135deg,var(--g900) 0%,var(--g800) 100%);color:white;padding:56px 24px 48px}
    .hero-inner{max-width:1100px;margin:0 auto}
    .breadcrumb{font-size:0.8rem;color:rgba(255,255,255,0.55);margin-bottom:16px}
    .breadcrumb a{color:rgba(255,255,255,0.55)}
    .breadcrumb a:hover{color:white}
    .page-hero h1{font-size:clamp(1.5rem,3.5vw,2.3rem);font-weight:800;margin-bottom:12px}
    .page-hero p{color:rgba(255,255,255,0.8);font-size:1rem;max-width:600px;margin-bottom:20px}
    .trust-bar{display:flex;gap:16px;flex-wrap:wrap;font-size:0.8rem;color:rgba(255,255,255,0.7);align-items:center}
    .trust-bar span{background:rgba(255,255,255,0.1);padding:5px 12px;border-radius:20px}
    .main{max-width:1100px;margin:0 auto;padding:56px 24px}
    .layout{display:grid;grid-template-columns:1fr 280px;gap:40px;align-items:start}
    @media(max-width:800px){.layout{grid-template-columns:1fr}}
    .section-eyebrow{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--g600);margin-bottom:8px}
    h2{font-size:clamp(1.2rem,2.5vw,1.6rem);font-weight:800;color:var(--g900);margin-bottom:16px}
    .services-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;margin-bottom:40px}
    .service-card{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:20px;transition:all 0.15s;display:flex;flex-direction:column;gap:10px}
    .service-card:hover{box-shadow:var(--shadow);border-color:var(--g600);transform:translateY(-2px)}
    .service-card-icon{font-size:1.8rem}
    .service-card-name{font-size:1rem;font-weight:700;color:var(--g900)}
    .service-card-desc{font-size:0.8rem;color:var(--muted);line-height:1.5;flex:1}
    .service-card-price{font-size:0.8rem;font-weight:600;color:var(--g700)}
    .service-card-cta{display:inline-flex;align-items:center;gap:4px;color:var(--g700);font-weight:700;font-size:0.8rem;margin-top:auto}
    .city-info-box{background:var(--g50);border:1px solid var(--g100);border-radius:var(--radius);padding:24px;margin-bottom:32px}
    .city-info-box h3{font-size:1rem;font-weight:700;color:var(--g900);margin-bottom:12px}
    .city-info-row{display:flex;gap:10px;margin-bottom:8px;font-size:0.875rem}
    .city-info-icon{flex-shrink:0;color:var(--g600)}
    .sidebar-card{background:var(--g900);color:white;border-radius:var(--radius);padding:24px;margin-bottom:20px}
    .sidebar-card h3{font-size:1rem;font-weight:700;margin-bottom:16px;color:var(--gold2)}
    .sidebar-cta{display:block;background:var(--gold);color:var(--g900);text-align:center;padding:13px;border-radius:8px;font-weight:800;font-size:0.9rem;margin-bottom:10px}
    .sidebar-phone{display:block;text-align:center;color:rgba(255,255,255,0.8);font-size:0.875rem;margin-bottom:16px}
    .nearby-cities{list-style:none;display:flex;flex-direction:column;gap:8px}
    .nearby-cities li a{font-size:0.875rem;color:rgba(255,255,255,0.75);display:flex;align-items:center;gap:6px}
    .nearby-cities li a:hover{color:white}
    footer{background:var(--g900);color:rgba(255,255,255,0.7);text-align:center;padding:28px 24px;font-size:0.8rem;margin-top:56px}
    footer a{color:var(--gold2);font-weight:700;margin:0 8px}
  </style>
</head>
<body>
<header class="site-header">
  <div class="header-inner">
    <a href="/es/" class="logo">
      <svg width="32" height="32" viewBox="0 0 38 38" fill="none" aria-hidden="true">
        <circle cx="19" cy="19" r="19" fill="#2d6b4e"/>
        <path d="M19 8C13 8 8 13 8 19s5 11 11 11c1.8 0 3.5-.5 5-1.3L19 24l-3-6 6-3 3 6-3 3.7C25.5 23 27 21 27 19c0-6-4-10.5-8-11z" fill="white"/>
        <path d="M19 8c.7 3 1.8 10-3 14.5" stroke="#d4a017" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
      <div><span class="logo-name">Las Vegas Landscaping</span><span class="logo-sub">Con Licencia • Asegurado</span></div>
    </a>
    <nav>
      <a href="/es/">Inicio</a>
      <a href="/es/areas">Áreas</a>
      <a href={`/areas/${ciudad}`} class="lang-link">🇺🇸 English</a>
      <a href="tel:7025288324" class="btn-call">📞 (702) 528-8324</a>
    </nav>
  </div>
</header>

<div class="page-hero">
  <div class="hero-inner">
    <div class="breadcrumb">
      <a href="/es/">Inicio</a> › <a href="/es/areas">Áreas</a> › {city.name}
    </div>
    <h1>Servicios de Paisajismo en {city.name}, NV</h1>
    <p>Paisajismo profesional en {city.name} — con licencia, asegurado y 100% compatible con AB356. {cityTrans.localNoteEs}</p>
    <div class="trust-bar">
      <span>4.9/5 ★ 500+ Reseñas</span>
      <span>Servicio en {city.name}</span>
      <span>Presupuesto Gratis</span>
    </div>
  </div>
</div>

<main class="main">
  <div class="layout">
    <div>
      <div class="section-eyebrow">Nuestros Servicios en {city.name}</div>
      <h2>Todos los Servicios de Paisajismo Disponibles</h2>
      <div class="services-grid">
        {services.map(s => {
          const t = serviceTranslations[s.slug];
          return (
            <a href={`/es/areas/${ciudad}/${s.slug}`} class="service-card">
              <div class="service-card-icon">{s.emoji}</div>
              <div class="service-card-name">{t?.nameEs || s.name}</div>
              <div class="service-card-desc">{t?.metaDescEs || s.metaDesc}</div>
              <div class="service-card-price">{t?.startingPriceEs || s.startingPrice}</div>
              <span class="service-card-cta">Ver servicio →</span>
            </a>
          );
        })}
      </div>

      <div class="city-info-box">
        <h3>Sobre el Paisajismo en {city.name}</h3>
        <div class="city-info-row"><span class="city-info-icon">🌡️</span><span>{city.climate}</span></div>
        {cityTrans.hoaNoteEs && <div class="city-info-row"><span class="city-info-icon">🏘️</span><span>{cityTrans.hoaNoteEs}</span></div>}
        <div class="city-info-row"><span class="city-info-icon">💧</span><span>El programa de rebaja SNWA está disponible para propietarios de {city.name}. Hasta $7 por pie cuadrado por remoción de pasto.</span></div>
        <div class="city-info-row"><span class="city-info-icon">📋</span><span>La Ley AB356 requiere la remoción de pasto ornamental no funcional antes del 31 de diciembre de 2026.</span></div>
      </div>
    </div>

    <aside>
      <div class="sidebar-card">
        <h3>Obtén Tu Presupuesto Gratis</h3>
        <a href="/es/#presupuesto" class="sidebar-cta">Presupuesto Instantáneo con IA →</a>
        <a href="tel:7025288324" class="sidebar-phone">📞 (702) 528-8324</a>
        {nearbyCities.length > 0 && (
          <>
            <div style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.5);margin-bottom:10px">Ciudades Cercanas</div>
            <ul class="nearby-cities">
              {nearbyCities.map(nc => (
                <li><a href={`/es/areas/${nc.slug}`}>🌵 {nc.name}</a></li>
              ))}
            </ul>
          </>
        )}
      </div>
    </aside>
  </div>
</main>

<footer>
  <div style="margin-bottom:10px">
    <a href="/es/">Inicio</a>
    <a href="/es/areas">Áreas de Servicio</a>
    <a href="/es/calculadora-rebate">Calculadora</a>
    <a href="tel:7025288324">(702) 528-8324</a>
    <a href={`/areas/${ciudad}`}>🇺🇸 English</a>
  </div>
  © {new Date().getFullYear()} Las Vegas Landscaping — Con Licencia • Asegurado
</footer>
</body>
</html>
