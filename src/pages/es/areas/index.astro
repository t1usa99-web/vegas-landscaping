---
import { cities } from '../../../data/cities.js';
import { services } from '../../../data/services.js';
import { serviceTranslations } from '../../../data/translations-es.js';
const SITE = 'https://lasvegaslandscaping.homepropeople.com';
const pageTitle = 'Áreas de Servicio de Paisajismo | Valle de Las Vegas | Las Vegas Landscaping';
const pageDesc = 'Servicios profesionales de paisajismo en todo el Valle de Las Vegas — Henderson, Summerlin, North Las Vegas, Green Valley, Anthem y todas las comunidades circundantes.';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`${SITE}/es/areas`} />
  <link rel="alternate" hreflang="en" href={`${SITE}/areas`} />
  <link rel="alternate" hreflang="es" href={`${SITE}/es/areas`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE}/areas`} />
  <meta property="og:url" content={`${SITE}/es/areas`} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap&font-display=swap" rel="stylesheet" />
  <style>
    :root{--g900:#0f2a1e;--g800:#1a4731;--g700:#2d6b4e;--g600:#3d8c62;--g100:#e8f4ee;--g50:#f4faf6;--gold:#d4a017;--gold2:#f0c040;--text:#1a1a1a;--muted:#6b7280;--border:#e2e8f0;--shadow:0 4px 20px rgba(0,0,0,0.08);--radius:12px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;color:var(--text);background:#fff;line-height:1.6}
    a{color:inherit;text-decoration:none}
    .site-header{background:var(--g900);padding:0 24px;position:sticky;top:0;z-index:100}
    .header-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:60px;gap:16px}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-name{font-weight:800;font-size:1rem;color:white;display:block}
    .logo-sub{font-size:0.7rem;color:rgba(255,255,255,0.55)}
    nav{display:flex;align-items:center;gap:16px}
    nav a{color:rgba(255,255,255,0.75);font-size:0.875rem;font-weight:500}
    nav a:hover{color:white}
    .btn-call{background:var(--gold);color:var(--g900)!important;padding:8px 16px;border-radius:6px;font-weight:700!important;font-size:0.8rem!important;white-space:nowrap}
    .lang-link{color:rgba(255,255,255,0.6);font-size:0.8rem;border:1px solid rgba(255,255,255,0.2);padding:4px 10px;border-radius:5px}
    .page-hero{background:linear-gradient(135deg,var(--g900) 0%,var(--g800) 100%);color:white;padding:56px 24px;text-align:center}
    .page-hero h1{font-size:clamp(1.6rem,3.5vw,2.4rem);font-weight:800;margin-bottom:12px}
    .page-hero p{color:rgba(255,255,255,0.8);font-size:1rem;max-width:560px;margin:0 auto}
    .breadcrumb{font-size:0.8rem;color:rgba(255,255,255,0.55);margin-bottom:16px}
    .breadcrumb a{color:rgba(255,255,255,0.55)}
    .breadcrumb a:hover{color:white}
    .main{max-width:1100px;margin:0 auto;padding:56px 24px}
    .section-eyebrow{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--g600);margin-bottom:8px}
    h2{font-size:clamp(1.3rem,2.5vw,1.7rem);font-weight:800;color:var(--g900);margin-bottom:12px}
    .cities-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;margin-bottom:64px}
    .city-card{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:24px;transition:box-shadow 0.15s,border-color 0.15s;display:flex;flex-direction:column;gap:12px}
    .city-card:hover{box-shadow:var(--shadow);border-color:var(--g600)}
    .city-card-header{display:flex;align-items:center;justify-content:space-between}
    .city-name{font-size:1.1rem;font-weight:700;color:var(--g900)}
    .city-badge{font-size:0.7rem;font-weight:600;background:var(--g100);color:var(--g700);padding:3px 10px;border-radius:20px}
    .city-climate{font-size:0.8rem;color:var(--muted);line-height:1.5}
    .city-services{display:flex;flex-wrap:wrap;gap:6px}
    .city-service-chip{font-size:0.75rem;background:var(--g50);border:1px solid var(--g100);color:var(--g700);padding:3px 10px;border-radius:20px;font-weight:500}
    .city-card-cta{display:inline-flex;align-items:center;gap:4px;color:var(--g700);font-weight:700;font-size:0.875rem;margin-top:4px}
    .services-strip{background:var(--g50);border-radius:var(--radius);padding:32px;margin-bottom:64px}
    .services-strip h2{margin-bottom:20px}
    .services-chips{display:flex;flex-wrap:wrap;gap:10px}
    .service-chip{background:white;border:1px solid var(--border);border-radius:8px;padding:10px 16px;font-size:0.875rem;font-weight:600;color:var(--g800);display:flex;align-items:center;gap:8px;transition:all 0.15s}
    .service-chip:hover{border-color:var(--g600);background:var(--g50)}
    footer{background:var(--g900);color:rgba(255,255,255,0.7);text-align:center;padding:28px 24px;font-size:0.8rem}
    footer a{color:var(--gold2);font-weight:700;margin:0 8px}
  </style>
</head>
<body>
<header class="site-header">
  <div class="header-inner">
    <a href="/es/" class="logo">
      <svg width="32" height="32" viewBox="0 0 38 38" fill="none" aria-hidden="true">
        <circle cx="19" cy="19" r="19" fill="#2d6b4e"/>
        <path d="M19 8C13 8 8 13 8 19s5 11 11 11c1.8 0 3.5-.5 5-1.3L19 24l-3-6 6-3 3 6-3 3.7C25.5 23 27 21 27 19c0-6-4-10.5-8-11z" fill="white"/>
        <path d="M19 8c.7 3 1.8 10-3 14.5" stroke="#d4a017" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
      <div><span class="logo-name">Las Vegas Landscaping</span><span class="logo-sub">Con Licencia • Asegurado</span></div>
    </a>
    <nav>
      <a href="/es/">Inicio</a>
      <a href="/es/calculadora-rebate">💧 Calculadora</a>
      <a href="/areas" class="lang-link">🇺🇸 English</a>
      <a href="tel:7025288324" class="btn-call">📞 (702) 528-8324</a>
    </nav>
  </div>
</header>

<div class="page-hero">
  <div class="breadcrumb"><a href="/es/">Inicio</a> › Áreas de Servicio</div>
  <h1>Áreas de Servicio de Paisajismo</h1>
  <p>Servicio profesional de paisajismo en todo el Valle de Las Vegas — desde Boulder City hasta Centennial Hills.</p>
</div>

<main class="main">
  <div class="section-eyebrow">Dónde Trabajamos</div>
  <h2 style="margin-bottom:32px">Todas las Ciudades que Servimos</h2>
  <div class="cities-grid">
    {cities.map(city => (
      <a href={`/es/areas/${city.slug}`} class="city-card">
        <div class="city-card-header">
          <span class="city-name">🌵 {city.name}</span>
          <span class="city-badge">NV</span>
        </div>
        <p class="city-climate">{city.climate?.split('—')[0]?.trim()}</p>
        <div class="city-services">
          {services.slice(0,4).map(s => (
            <span class="city-service-chip">{serviceTranslations[s.slug]?.shortNameEs || s.shortName}</span>
          ))}
          <span class="city-service-chip">+{services.length - 4} más</span>
        </div>
        <span class="city-card-cta">Ver servicios en {city.name} →</span>
      </a>
    ))}
  </div>

  <div class="services-strip">
    <div class="section-eyebrow">Nuestros Servicios</div>
    <h2>Todos los Servicios Disponibles en Cada Ciudad</h2>
    <div class="services-chips">
      {services.map(s => (
        <a href={`/es/areas/las-vegas/${s.slug}`} class="service-chip">
          <span>{s.emoji}</span> {serviceTranslations[s.slug]?.nameEs || s.name}
        </a>
      ))}
    </div>
  </div>
</main>

<footer>
  <div style="margin-bottom:10px">
    <a href="/es/">Inicio</a>
    <a href="/es/areas">Áreas de Servicio</a>
    <a href="/es/calculadora-rebate">Calculadora</a>
    <a href="tel:7025288324">(702) 528-8324</a>
    <a href="/areas">🇺🇸 English</a>
  </div>
  © {new Date().getFullYear()} Las Vegas Landscaping — Con Licencia • Asegurado
</footer>
</body>
</html>
