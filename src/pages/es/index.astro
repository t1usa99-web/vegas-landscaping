---
import { services } from '../../data/services.js';
import { cities } from '../../data/cities.js';
import { serviceTranslations } from '../../data/translations-es.js';
const SITE = 'https://lasvegaslandscaping.homepropeople.com';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Paisajismo Las Vegas | Xeriscape, Patio y Jardín Desértico | Las Vegas Landscaping</title>
  <meta name="description" content="Paisajismo profesional en Las Vegas. Xeriscape, césped artificial, patios, pérgolas, palmeras, riego por goteo y más. Con licencia y asegurados. Presupuesto gratuito con IA." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`${SITE}/es/`} />
  <link rel="alternate" hreflang="en" href={`${SITE}/`} />
  <link rel="alternate" hreflang="es" href={`${SITE}/es/`} />
  <link rel="alternate" hreflang="x-default" href={`${SITE}/`} />
  <meta property="og:url" content={`${SITE}/es/`} />
  <meta property="og:title" content="Paisajismo Las Vegas — Especialistas en Jardín Desértico" />
  <meta property="og:description" content="Transforma tu espacio exterior con el equipo de paisajismo de confianza en Las Vegas. 1,000+ proyectos, calificación 4.9★, presupuesto instantáneo gratis." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap&font-display=swap" rel="stylesheet" />
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Las Vegas Landscaping",
    "description": "Paisajismo profesional, construcción y diseño de espacios exteriores para Las Vegas, Henderson, Summerlin y áreas circundantes.",
    "telephone": "+17025288324",
    "email": "info@homepropeople.com",
    "address": { "@type": "PostalAddress", "addressLocality": "Las Vegas", "addressRegion": "NV", "postalCode": "89101" },
    "geo": { "@type": "GeoCoordinates", "latitude": 36.1699, "longitude": -115.1398 },
    "openingHours": ["Mo-Fr 07:00-18:00", "Sa 08:00-16:00"],
    "priceRange": "$$",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "500" },
    "areaServed": ["Las Vegas","Henderson","Summerlin","North Las Vegas","Green Valley","Boulder City","Enterprise","Paradise","Spring Valley"],
    "inLanguage": "es"
  })}</script>
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Todavía se permite el pasto decorativo en Las Vegas?", "acceptedAnswer": { "@type": "Answer", "text": "No. La Ley AB356 de Nevada, firmada en 2021, prohíbe la instalación de pasto ornamental no funcional en el Valle de Las Vegas para 2027. Nos especializamos en hermosas alternativas compatibles con el agua, incluyendo césped artificial, xeriscape, grava decorativa y plantas nativas del desierto." } },
      { "@type": "Question", "name": "¿Necesito aprobación del HOA antes de comenzar?", "acceptedAnswer": { "@type": "Answer", "text": "Depende de tu vecindario. La mayoría de las comunidades planeadas en Summerlin, Henderson y Green Valley requieren aprobación del HOA para cambios de paisajismo. Hemos trabajado con cientos de HOAs en Las Vegas y conocemos sus requisitos. Podemos ayudarte a preparar tu paquete de solicitud." } },
      { "@type": "Question", "name": "¿Cuál es la mejor época del año para hacer paisajismo en Las Vegas?", "acceptedAnswer": { "@type": "Answer", "text": "La primavera (marzo–mayo) y el otoño (septiembre–noviembre) son ideales. Las plantas del desierto se establecen mejor con temperaturas moderadas. Sin embargo, trabajamos todo el año — la construcción de patios, el riego y muchos otros proyectos se pueden hacer de forma segura en verano." } },
      { "@type": "Question", "name": "¿Cuánto tarda un proyecto típico de paisajismo?", "acceptedAnswer": { "@type": "Answer", "text": "Varía según el alcance. Un xeriscape básico o limpieza tarda 1–3 días. Un rediseño completo del jardín delantero normalmente toma 3–7 días. Un jardín trasero complejo con patio, pérgola, fogón e iluminación suele tardar 2–4 semanas." } },
      { "@type": "Question", "name": "¿Tienen licencia y seguro en Nevada?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Estamos completamente licenciados por la Junta de Contratistas del Estado de Nevada, contamos con seguro de responsabilidad general y mantenemos cobertura de compensación laboral para todos los miembros del equipo." } }
    ]
  })}</script>
  <style>
    :root {
      --g900:#0f2a1e;--g800:#1a4731;--g700:#2d6b4e;--g600:#3d8c62;--g500:#4da875;
      --g100:#e8f4ee;--g50:#f4faf6;
      --gold:#d4a017;--gold2:#f0c040;
      --text:#1a1a1a;--muted:#6b7280;--border:#e2e8f0;
      --shadow:0 4px 20px rgba(0,0,0,0.08);--radius:12px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;color:var(--text);background:#fff;line-height:1.6}
    a{color:inherit;text-decoration:none}
    .container{max-width:1100px;margin:0 auto;padding:0 24px}

    /* Header */
    .site-header{background:var(--g900);padding:0 24px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,0.3)}
    .header-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:64px;gap:16px}
    .logo{display:flex;align-items:center;gap:10px}
    .logo-name{font-weight:800;font-size:1rem;color:white;display:block}
    .logo-tag{font-size:0.7rem;color:rgba(255,255,255,0.55)}
    .header-nav{display:flex;align-items:center;gap:20px}
    .header-nav a{color:rgba(255,255,255,0.75);font-size:0.875rem;font-weight:500;transition:color 0.15s}
    .header-nav a:hover{color:white}
    .header-cta{display:flex;align-items:center;gap:6px;background:var(--gold);color:var(--g900);padding:9px 18px;border-radius:7px;font-weight:700;font-size:0.875rem;white-space:nowrap;transition:background 0.15s}
    .header-cta:hover{background:var(--gold2)}
    .lang-switch{color:rgba(255,255,255,0.6);font-size:0.8rem;border:1px solid rgba(255,255,255,0.2);padding:4px 10px;border-radius:5px}
    .lang-switch:hover{color:white;border-color:rgba(255,255,255,0.5)}
    @media(max-width:700px){.header-nav{display:none}}

    /* Hero */
    .hero{background:linear-gradient(135deg,var(--g900) 0%,var(--g800) 60%,#1f5c3a 100%);color:white;padding:80px 24px 72px;text-align:center;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(240,192,64,0.15);border:1px solid rgba(240,192,64,0.3);color:var(--gold2);font-size:0.8rem;font-weight:600;padding:6px 14px;border-radius:20px;margin-bottom:20px;position:relative}
    .hero h1{font-size:clamp(1.9rem,4.5vw,3rem);font-weight:800;line-height:1.15;margin-bottom:18px;position:relative}
    .hero h1 em{font-style:normal;color:var(--gold2)}
    .hero>div>p{font-size:1.1rem;color:rgba(255,255,255,0.82);max-width:580px;margin:0 auto 32px;position:relative}
    .hero-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:24px;position:relative}
    .btn-hero-primary{background:var(--gold);color:var(--g900);padding:14px 28px;border-radius:8px;font-weight:800;font-size:1rem;transition:background 0.15s}
    .btn-hero-primary:hover{background:var(--gold2)}
    .btn-hero-secondary{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.25);color:white;padding:14px 22px;border-radius:8px;font-weight:600;font-size:0.9rem;backdrop-filter:blur(4px);transition:background 0.15s}
    .btn-hero-secondary:hover{background:rgba(255,255,255,0.18)}
    .hero-badges{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;position:relative}
    .hbadge{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);padding:6px 14px;border-radius:20px;font-size:0.8rem;font-weight:500}

    /* Stats */
    .stats-bar{background:white;border-bottom:1px solid var(--border);padding:20px 24px}
    .stats-inner{display:flex;justify-content:center;align-items:center;gap:32px;flex-wrap:wrap}
    .stat{text-align:center}
    .stat-num{font-size:1.5rem;font-weight:800;color:var(--g800)}
    .stat-lbl{font-size:0.75rem;color:var(--muted);margin-top:2px}
    .stat-divider{width:1px;height:40px;background:var(--border)}
    @media(max-width:500px){.stat-divider{display:none}}

    /* Section headers */
    .section-header{text-align:center;margin-bottom:48px}
    .section-header.light{color:white}
    .section-eyebrow{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--g600);margin-bottom:10px}
    .section-header.light .section-eyebrow{color:var(--gold2)}
    .section-header h2{font-size:clamp(1.5rem,3vw,2.1rem);font-weight:800;color:var(--g900);margin-bottom:12px;line-height:1.2}
    .section-header.light h2{color:white}
    .section-header p{color:var(--muted);font-size:1rem;max-width:560px;margin:0 auto}
    .section-header.light p{color:rgba(255,255,255,0.75)}

    /* Services */
    .services-section{padding:72px 0;background:var(--g50)}
    .service-columns{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:40px}
    @media(max-width:800px){.service-columns{grid-template-columns:1fr}}
    .service-col{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:28px;display:flex;flex-direction:column;gap:14px}
    .service-col.featured{border-color:var(--g600);box-shadow:0 0 0 2px var(--g600),var(--shadow);position:relative}
    .service-col-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--g700);color:white;font-size:0.7rem;font-weight:700;padding:4px 14px;border-radius:20px;white-space:nowrap;text-transform:uppercase;letter-spacing:0.05em}
    .service-col-icon{font-size:2rem}
    .service-col h3{font-size:1.1rem;font-weight:700;color:var(--g900)}
    .service-col-desc{font-size:0.875rem;color:var(--muted);line-height:1.6}
    .service-list{list-style:none;display:flex;flex-direction:column;gap:6px;flex:1}
    .service-list li{font-size:0.875rem;color:var(--text);display:flex;align-items:center;gap:8px}
    .service-list li::before{content:'✓';color:var(--g600);font-weight:700;font-size:0.8rem;flex-shrink:0}
    .service-col-cta{display:inline-flex;align-items:center;color:var(--g700);font-weight:700;font-size:0.875rem;margin-top:auto;padding-top:8px}
    .service-col-cta:hover{color:var(--g900)}
    .services-cta-bar{background:var(--g800);color:white;border-radius:var(--radius);padding:28px 32px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap}
    .services-cta-bar p{font-size:1rem;color:rgba(255,255,255,0.85)}
    .btn-primary{background:var(--g700);color:white;padding:12px 24px;border-radius:8px;font-weight:700;font-size:0.9rem;transition:background 0.15s;display:inline-flex;align-items:center;gap:6px;white-space:nowrap}
    .btn-primary:hover{background:var(--g800)}

    /* Estimate Form */
    .estimate-section{background:var(--g900);padding:80px 24px;color:white}
    .estimate-inner{max-width:780px;margin:0 auto}
    .estimate-inner .section-eyebrow{color:var(--gold2)}
    .estimate-inner h2{color:white;font-size:clamp(1.5rem,3vw,2rem);font-weight:800;margin-bottom:8px}
    .estimate-inner>p{color:rgba(255,255,255,0.75);margin-bottom:40px}
    .form-card{background:white;border-radius:var(--radius);padding:36px;color:var(--text)}
    .step-indicator{display:flex;align-items:center;gap:8px;margin-bottom:28px}
    .step-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;flex-shrink:0}
    .step-dot.active{background:var(--g700);color:white}
    .step-dot.done{background:var(--g100);color:var(--g700)}
    .step-dot.inactive{background:var(--border);color:var(--muted)}
    .step-line{flex:1;height:2px;background:var(--border)}
    .step-line.done{background:var(--g600)}
    .step-title{font-size:1.2rem;font-weight:700;color:var(--g900);margin-bottom:6px}
    .step-subtitle{font-size:0.875rem;color:var(--muted);margin-bottom:24px}
    .hidden{display:none}
    .service-category-title{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin:20px 0 10px}
    .service-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;margin-bottom:4px}
    .service-item{display:flex;align-items:center;gap:10px;padding:12px 14px;border:1.5px solid var(--border);border-radius:8px;cursor:pointer;transition:all 0.15s;font-size:0.875rem}
    .service-item:hover{border-color:var(--g500);background:var(--g50)}
    .service-item input{display:none}
    .service-item.checked{border-color:var(--g600);background:var(--g50)}
    .service-icon{font-size:1.1rem;flex-shrink:0}
    .service-name{font-weight:500;line-height:1.3}
    .service-count{font-size:0.8rem;color:var(--g700);font-weight:600;margin-top:8px;min-height:20px}
    .error-box{background:#fef2f2;border:1px solid #fca5a5;color:#dc2626;padding:10px 14px;border-radius:8px;font-size:0.875rem;margin-top:12px;display:none}
    .error-box.show{display:block}
    .btn-group{display:flex;gap:12px;justify-content:flex-end;margin-top:24px}
    .btn-group.btn-end{justify-content:flex-end}
    .btn-secondary{background:var(--g50);border:1.5px solid var(--border);color:var(--text);padding:11px 20px;border-radius:8px;font-weight:600;font-size:0.875rem;cursor:pointer;transition:all 0.15s}
    .btn-secondary:hover{border-color:var(--g600);color:var(--g700)}
    button.btn-primary{border:none;cursor:pointer;font-family:inherit}
    .form-group{margin-bottom:18px}
    .form-group label{display:block;font-size:0.8rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px}
    .form-group input,.form-group select,.form-group textarea{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-size:0.95rem;font-family:inherit;color:var(--text);transition:border-color 0.15s}
    .form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:var(--g600)}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    @media(max-width:540px){.form-row{grid-template-columns:1fr}}
    .radio-group{display:flex;flex-wrap:wrap;gap:8px}
    .radio-item{display:flex;align-items:center;gap:8px;padding:9px 14px;border:1.5px solid var(--border);border-radius:8px;cursor:pointer;font-size:0.875rem;transition:all 0.15s}
    .radio-item:hover{border-color:var(--g500)}
    .radio-item.selected{border-color:var(--g600);background:var(--g50);color:var(--g800);font-weight:600}
    .radio-item input{display:none}
    .required{color:#dc2626}
    .optional{color:var(--muted);font-weight:400;font-size:0.8rem;text-transform:none;letter-spacing:0}
    .privacy-note{font-size:0.8rem;color:var(--muted);margin-bottom:12px}
    .generating-state{text-align:center;padding:40px 20px;color:var(--g800)}
    .spinner{width:40px;height:40px;border:3px solid var(--g100);border-top-color:var(--g700);border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 16px}
    @keyframes spin{to{transform:rotate(360deg)}}
    .estimate-result{padding:4px 0}
    .estimate-total-box{background:var(--g50);border:2px solid var(--g600);border-radius:10px;padding:20px;text-align:center;margin-bottom:20px}
    .estimate-total-label{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--g600);margin-bottom:4px}
    .estimate-total-amount{font-size:2rem;font-weight:800;color:var(--g900)}
    .estimate-timeline{font-size:0.85rem;color:var(--muted);margin-top:4px}
    .estimate-summary{font-size:0.95rem;color:var(--text);line-height:1.7;margin-bottom:20px;padding:16px;background:var(--g50);border-radius:8px}
    .line-items{border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:20px}
    .line-item{display:grid;grid-template-columns:1fr auto;gap:16px;padding:14px 16px;border-bottom:1px solid var(--border);font-size:0.875rem}
    .line-item:last-child{border-bottom:none}
    .line-item:nth-child(even){background:var(--g50)}
    .line-item-name{font-weight:600;color:var(--g900)}
    .line-item-desc{font-size:0.8rem;color:var(--muted);margin-top:2px}
    .line-item-price{font-weight:700;color:var(--g800);white-space:nowrap;text-align:right}
    .line-item-time{font-size:0.75rem;color:var(--muted);text-align:right}
    .lv-notes{background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:16px;margin-bottom:16px}
    .lv-notes-title{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#92400e;margin-bottom:8px}
    .lv-notes ul{list-style:none;display:flex;flex-direction:column;gap:6px}
    .lv-notes li{font-size:0.85rem;color:#78350f;display:flex;gap:8px}
    .lv-notes li::before{content:'💡';flex-shrink:0}
    .estimate-disclaimer{font-size:0.75rem;color:var(--muted);line-height:1.5;padding-top:12px;border-top:1px solid var(--border)}
    .estimate-cta-bar{display:flex;gap:12px;flex-wrap:wrap;margin-top:20px}
    .btn-call-cta{display:flex;align-items:center;gap:8px;background:var(--g700);color:white;padding:13px 20px;border-radius:8px;font-weight:700;font-size:0.9rem;transition:background 0.15s}
    .btn-call-cta:hover{background:var(--g800)}
    .btn-restart{background:var(--g50);border:1.5px solid var(--border);color:var(--text);padding:12px 20px;border-radius:8px;font-weight:600;font-size:0.875rem;cursor:pointer;font-family:inherit;transition:all 0.15s}
    .btn-restart:hover{border-color:var(--g600)}

    /* Testimonials */
    .testimonials-section{background:var(--g800);padding:72px 24px;color:white}
    .testimonials-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;margin-top:40px}
    .testimonial-card{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:var(--radius);padding:24px}
    .stars{color:var(--gold2);font-size:0.9rem;margin-bottom:10px}
    .testimonial-text{font-size:0.9rem;color:rgba(255,255,255,0.85);line-height:1.7;margin-bottom:14px;font-style:italic}
    .testimonial-author{font-size:0.8rem;font-weight:600;color:rgba(255,255,255,0.6)}

    /* Areas */
    .areas-section{padding:72px 24px;background:white}
    .city-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-top:32px}
    .city-link{background:var(--g50);border:1px solid var(--g100);border-radius:8px;padding:12px 16px;font-size:0.875rem;font-weight:600;color:var(--g800);text-align:center;transition:all 0.15s}
    .city-link:hover{background:var(--g100);border-color:var(--g600);color:var(--g900)}

    /* FAQ */
    .faq-section{background:var(--g50);padding:72px 24px}
    .faq-wrap{max-width:720px;margin:0 auto}
    .faq-item{background:white;border:1px solid var(--border);border-radius:10px;margin-bottom:10px;overflow:hidden}
    .faq-q{width:100%;display:flex;justify-content:space-between;align-items:center;padding:18px 22px;background:none;border:none;cursor:pointer;font-size:0.95rem;font-weight:600;color:var(--g900);text-align:left;font-family:inherit;transition:background 0.15s}
    .faq-q:hover{background:var(--g50)}
    .faq-icon{font-size:1.25rem;font-weight:300;color:var(--g600);flex-shrink:0;transition:transform 0.2s}
    .faq-item.open .faq-q{background:var(--g50)}
    .faq-item.open .faq-icon{transform:rotate(45deg)}
    .faq-a{display:none;padding:0 22px 18px;color:var(--muted);font-size:0.9rem;line-height:1.7}
    .faq-item.open .faq-a{display:block}

    /* Footer */
    footer{background:var(--g900);color:rgba(255,255,255,0.65);padding:32px 24px;text-align:center;font-size:0.8rem}
    footer a{color:var(--gold2);font-weight:600;margin:0 8px}
