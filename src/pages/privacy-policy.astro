---
export const prerender = true;
const updated = 'March 11, 2026';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Privacy Policy — Las Vegas Landscaping</title>
  <meta name="description" content="Privacy Policy for Las Vegas Landscaping — a free lead generation service connecting homeowners with local landscaping contractors." />
  <meta name="robots" content="noindex, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --g900: #0f2a1e; --g800: #1a4731; --g700: #2d6b4e; --g600: #3d8c62;
      --g100: #e8f4ee; --g50: #f4faf6;
      --gold: #d4a017; --gold2: #f0c040;
      --text: #1a1a1a; --muted: #6b7280; --border: #e2e8f0;
      --radius: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; color: var(--text); background: #fff; line-height: 1.6; }
    a { color: var(--g700); }

    /* Header */
    .site-header { background: var(--g900); padding: 0 24px; position: sticky; top: 0; z-index: 100; }
    .header-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 60px; gap: 16px; }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-text-wrap .logo-name { font-weight: 800; font-size: 1rem; color: white; display: block; }
    .logo-text-wrap .logo-sub { font-size: 0.7rem; color: rgba(255,255,255,0.55); }
    nav { display: flex; align-items: center; gap: 20px; }
    nav a { color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    nav a:hover { color: white; }
    .btn-call { background: var(--gold); color: var(--g900) !important; padding: 8px 16px; border-radius: 6px; font-weight: 700 !important; font-size: 0.8rem !important; white-space: nowrap; }

    /* Hero */
    .hero { background: linear-gradient(135deg, var(--g900) 0%, var(--g800) 60%, var(--g700) 100%); color: white; padding: 64px 24px 48px; text-align: center; }
    .hero h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; line-height: 1.2; margin-bottom: 12px; }
    .hero p { font-size: 0.9rem; color: rgba(255,255,255,0.65); }

    /* Content */
    .content { max-width: 780px; margin: 0 auto; padding: 56px 24px 80px; }
    .section { margin-bottom: 40px; }
    .section h2 { font-size: 1.2rem; font-weight: 700; color: var(--g800); margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid var(--g100); }
    .section p { color: #444; margin-bottom: 12px; font-size: 0.93rem; }
    .section ul { color: #444; font-size: 0.93rem; padding-left: 20px; margin-bottom: 12px; }
    .section ul li { margin-bottom: 6px; }

    /* Table of contents */
    .toc { background: var(--g50); border: 1px solid var(--g100); border-radius: var(--radius); padding: 20px 24px; margin-bottom: 40px; }
    .toc-title { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 10px; }
    .toc ol { padding-left: 20px; }
    .toc li { font-size: 0.875rem; margin-bottom: 4px; }
    .toc a { color: var(--g700); text-decoration: none; font-weight: 500; }
    .toc a:hover { text-decoration: underline; }

    /* Footer */
    footer { background: var(--g900); color: rgba(255,255,255,0.6); text-align: center; padding: 28px 24px; font-size: 0.8rem; }
    footer a { color: var(--gold2); text-decoration: none; font-weight: 600; margin: 0 8px; }
    .footer-links { margin: 10px 0; }
  </style>
</head>
<body>

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <svg width="32" height="32" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="19" cy="19" r="19" fill="#2d6b4e"/>
        <path d="M19 8C13 8 8 13 8 19s5 11 11 11c1.8 0 3.5-.5 5-1.3L19 24l-3-6 6-3 3 6-3 3.7C25.5 23 27 21 27 19c0-6-4-10.5-8-11z" fill="white"/>
        <path d="M19 8c.7 3 1.8 10-3 14.5" stroke="#d4a017" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
      <div class="logo-text-wrap">
        <span class="logo-name">Las Vegas Landscaping</span>
        <span class="logo-sub">Licensed • Insured</span>
      </div>
    </a>
    <nav>
      <a href="/">Home</a>
      <a href="/areas">Service Areas</a>
      <a href="tel:7025288324" class="btn-call">📞 (702) 528-8324</a>
    </nav>
  </div>
</header>

<section class="hero">
  <h1>Privacy Policy</h1>
  <p>Last updated: {updated}</p>
</section>

<div class="content">

  <div class="toc">
    <div class="toc-title">Contents</div>
    <ol>
      <li><a href="#who-we-are">Who We Are</a></li>
      <li><a href="#information-collected">Information We Collect</a></li>
      <li><a href="#how-used">How We Use Your Information</a></li>
      <li><a href="#sharing">Information Sharing & Third Parties</a></li>
      <li><a href="#cookies">Cookies & Session Data</a></li>
      <li><a href="#retention">Data Retention</a></li>
      <li><a href="#rights">Your Rights</a></li>
      <li><a href="#contact">Contact for Privacy Requests</a></li>
    </ol>
  </div>

  <div class="section" id="who-we-are">
    <h2>1. Who We Are</h2>
    <p>Las Vegas Landscaping (accessible at lasvegaslandscaping.homepropeople.com) is a <strong>free lead generation service</strong>. We are not a landscaping contractor. Our purpose is to connect homeowners in the Las Vegas Valley with local licensed landscaping contractors by collecting estimate requests and forwarding them to contractors in your area.</p>
    <p>By using this website and submitting an estimate request, you understand and agree that your information will be shared with third-party contractors as described in this policy.</p>
  </div>

  <div class="section" id="information-collected">
    <h2>2. Information We Collect</h2>
    <p>When you submit an estimate request through our website, we collect the following personal information:</p>
    <ul>
      <li><strong>Name</strong> (first and last)</li>
      <li><strong>Phone number</strong></li>
      <li><strong>Email address</strong></li>
      <li><strong>Service address</strong> (street address and city)</li>
      <li><strong>Property details</strong> (lot size, grass square footage, number of trees)</li>
      <li><strong>Service type requested</strong> (e.g., xeriscape, grass removal, artificial turf)</li>
      <li><strong>Additional notes</strong> you choose to include</li>
    </ul>
    <p>We do not collect payment information, social security numbers, or other sensitive financial or identity data.</p>
  </div>

  <div class="section" id="how-used">
    <h2>3. How We Use Your Information</h2>
    <p>We use the information you submit for the following purposes:</p>
    <ul>
      <li><strong>To connect you with a local contractor:</strong> Your name, contact information, and project details are shared with one or more licensed landscaping contractors in the Las Vegas area so they can contact you about your project.</li>
      <li><strong>To generate an AI-powered estimate:</strong> Your property details are sent to an AI service to produce an instant ballpark cost estimate displayed to you on the site.</li>
      <li><strong>To send confirmation emails:</strong> We may send a confirmation email to the address you provide acknowledging receipt of your request.</li>
      <li><strong>To notify our team:</strong> Our internal team receives notification of new requests to monitor service quality.</li>
    </ul>
    <p>We do not use your information for marketing to you directly, and we do not sell your data to unrelated third parties.</p>
  </div>

  <div class="section" id="sharing">
    <h2>4. Information Sharing & Third Parties</h2>
    <p>We share your information with the following parties:</p>
    <ul>
      <li><strong>Local landscaping contractors:</strong> Your full request (name, phone, email, address, and project details) is shared with one or more licensed contractors in your area. This sharing is the core purpose of this service.</li>
      <li><strong>Anthropic (Claude AI):</strong> Your property details (lot size, service type, grass square footage) are sent to Anthropic's API to generate an AI-powered cost estimate. Anthropic's privacy policy applies to data processed through their API. We do not send your name or contact information to Anthropic.</li>
      <li><strong>Resend:</strong> We use Resend to deliver email notifications. Your email address may be processed by Resend's servers to send confirmation or notification emails.</li>
      <li><strong>Railway:</strong> This website is hosted on Railway's cloud infrastructure. Your data is stored on Railway-managed servers.</li>
    </ul>
    <p>We do not sell, rent, or trade your personal information to unrelated third-party marketers or data brokers.</p>
  </div>

  <div class="section" id="cookies">
    <h2>5. Cookies & Session Data</h2>
    <p>This website uses minimal cookies:</p>
    <ul>
      <li><strong>Admin session cookie:</strong> A single HttpOnly, Secure session cookie (<code>admin_session</code>) is used exclusively for the password-protected admin area. This cookie is not set for regular visitors and is not used for tracking.</li>
    </ul>
    <p>We do not use advertising cookies, analytics cookies, or third-party tracking pixels. We do not use Google Analytics or similar services.</p>
  </div>

  <div class="section" id="retention">
    <h2>6. Data Retention</h2>
    <p>Submitted lead data is retained in our system for as long as necessary to operate the service and fulfill our business purposes, typically no longer than 24 months from the date of submission. You may request deletion of your data at any time (see Section 8 below).</p>
  </div>

  <div class="section" id="rights">
    <h2>7. Your Rights</h2>
    <p>Depending on your location, you may have rights under applicable privacy laws, including:</p>
    <ul>
      <li><strong>Nevada:</strong> Nevada Revised Statutes Chapter 603A grants Nevada residents the right to opt out of the sale of their personal information. We do not sell personal information, so no opt-out is necessary.</li>
      <li><strong>California (CCPA):</strong> California residents have the right to know what personal information is collected, request deletion, and opt out of the sale of personal information. We do not sell personal information.</li>
      <li><strong>Access & Correction:</strong> You may request access to or correction of the information we hold about you.</li>
      <li><strong>Deletion:</strong> You may request that we delete your personal information from our records.</li>
    </ul>
    <p>To exercise any of these rights, contact us at the address in Section 8.</p>
  </div>

  <div class="section" id="contact">
    <h2>8. Contact for Privacy Requests</h2>
    <p>For privacy-related requests, questions, or concerns — including requests to access, correct, or delete your data — please contact us:</p>
    <ul>
      <li><strong>Email:</strong> <a href="mailto:info@lasvegaslandscaping.homepropeople.com">info@lasvegaslandscaping.homepropeople.com</a></li>
      <li><strong>Phone:</strong> <a href="tel:7025288324">(702) 528-8324</a></li>
    </ul>
    <p>We will respond to verifiable requests within 45 days.</p>
    <p style="margin-top:20px;color:var(--muted);font-size:0.875rem">This Privacy Policy was last updated on {updated}. We may update this policy from time to time. Continued use of the website after changes constitutes acceptance of the updated policy.</p>
  </div>

</div>

<footer>
  <div>
    <a href="/">Home</a>
    <a href="/areas">Service Areas</a>
    <a href="/rebate-calculator">Rebate Calculator</a>
    <a href="tel:7025288324">(702) 528-8324</a>
  </div>
  <div class="footer-links">
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/privacy-policy">Privacy Policy</a>
    <a href="/terms">Terms of Service</a>
  </div>
  &copy; {new Date().getFullYear()} Las Vegas Landscaping — Licensed &bull; Bonded &bull; Insured &bull; Nevada AB356 Compliant
</footer>

</body>
</html>
