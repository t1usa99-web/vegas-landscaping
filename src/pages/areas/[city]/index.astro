---
import { services } from '../../../data/services.js';
import { cities, getCity, getNearbyCities } from '../../../data/cities.js';

const { city: citySlug } = Astro.params;
const city = getCity(citySlug);

if (!city) {
  return Astro.redirect('/areas');
}

const nearbyCities = getNearbyCities(citySlug);

const pageTitle = `Landscaping Services in ${city.name}, NV | Las Vegas Landscaping`;
const pageDesc = `Professional landscaping in ${city.name}, Nevada. Xeriscape, patio installation, artificial turf, drip irrigation, palm trees, and more. Licensed, insured, and AB356 compliant.`;

// Pre-compute JSON-LD in frontmatter to avoid template literal issues in JSX attributes
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Las Vegas Landscaping",
  "description": pageDesc,
  "areaServed": city.name,
  "telephone": "(702) 528-8324",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city.name,
    "addressRegion": "NV",
    "addressCountry": "US"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Landscaping Services in " + city.name,
    "itemListElement": services.map((s, i) => ({
      "@type": "Offer",
      "position": i + 1,
      "name": s.name,
      "description": s.metaDesc
    }))
  }
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`https://lasvegaslandscaping.homepropeople.com/areas/${citySlug}`} />
  <meta property="og:url" content={`https://lasvegaslandscaping.homepropeople.com/areas/${citySlug}`} />
  <link rel="alternate" hreflang="en" href={`https://lasvegaslandscaping.homepropeople.com/areas/${citySlug}`} />
  <link rel="alternate" hreflang="es" href={`https://lasvegaslandscaping.homepropeople.com/es/areas/${citySlug}`} />
  <link rel="alternate" hreflang="x-default" href={`https://lasvegaslandscaping.homepropeople.com/areas/${citySlug}`} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:type" content="website" />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lasvegaslandscaping.homepropeople.com/" },
      { "@type": "ListItem", "position": 2, "name": "Service Areas", "item": "https://lasvegaslandscaping.homepropeople.com/areas" },
      { "@type": "ListItem", "position": 3, "name": city.name, "item": `https://lasvegaslandscaping.homepropeople.com/areas/${citySlug}` }
    ]
  })} />

  <style>
    :root {
      --g900: #0f2a1e;
      --g800: #1a4731;
      --g700: #2d6b4e;
      --g100: #e8f4ee;
      --gold: #d4a017;
      --gold2: #f0c040;
      --sand: #faf8f4;
      --text: #1a1a1a;
      --muted: #666;
      --radius: 12px;
      --shadow: 0 4px 24px rgba(0,0,0,0.1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; color: var(--text); background: #fff; }

    /* Header */
    .site-header { background: var(--g800); position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 12px rgba(0,0,0,0.2); }
    .header-inner { max-width: 1280px; margin: 0 auto; padding: 0 24px; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-icon { width: 36px; height: 36px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
    .logo-text { color: #fff; font-weight: 700; font-size: 1rem; line-height: 1.1; }
    .logo-sub { color: rgba(255,255,255,0.6); font-size: 0.7rem; font-weight: 400; }
    nav { display: flex; align-items: center; gap: 24px; }
    nav a { color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.9rem; transition: color 0.2s; }
    nav a:hover { color: var(--gold2); }
    .btn-call { background: var(--gold); color: #1a1a1a; padding: 8px 18px; border-radius: 8px; font-weight: 700; font-size: 0.875rem; text-decoration: none; white-space: nowrap; }

    /* Breadcrumb */
    .breadcrumb { background: #f5f5f5; border-bottom: 1px solid #e5e5e5; padding: 10px 0; }
    .breadcrumb-inner { max-width: 1280px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; gap: 6px; font-size: 0.8rem; color: var(--muted); }
    .breadcrumb a { color: var(--g700); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb span { color: #999; }

    /* Hero */
    .hero {
      background: linear-gradient(135deg, var(--g900) 0%, var(--g800) 50%, var(--g700) 100%);
      color: #fff;
      padding: 52px 24px 44px;
    }
    .hero-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: center; }
    .hero-eyebrow { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }
    .hero h1 { font-size: clamp(1.75rem, 3.5vw, 2.75rem); font-weight: 900; margin-bottom: 14px; line-height: 1.1; }
    .hero-desc { font-size: 1rem; opacity: 0.85; line-height: 1.65; margin-bottom: 24px; max-width: 560px; }
    .hero-badges { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }
    .hero-badge { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); padding: 5px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-gold { background: var(--gold); color: #1a1a1a; padding: 12px 24px; border-radius: 8px; font-weight: 700; font-size: 0.95rem; text-decoration: none; }
    .btn-outline-w { background: transparent; border: 2px solid rgba(255,255,255,0.4); color: #fff; padding: 12px 24px; border-radius: 8px; font-weight: 700; font-size: 0.95rem; text-decoration: none; }
    .hero-stat-box { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; padding: 24px 28px; text-align: center; min-width: 180px; }
    .hero-stat-num { font-size: 2.5rem; font-weight: 900; color: var(--gold2); }
    .hero-stat-label { font-size: 0.75rem; opacity: 0.75; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px; }

    /* Layout */
    .page-wrap { max-width: 1280px; margin: 0 auto; padding: 48px 24px 80px; display: grid; grid-template-columns: 1fr 280px; gap: 48px; align-items: start; }

    /* Services Grid */
    .services-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 48px; }
    .service-card {
      background: #fff;
      border: 1.5px solid #e5e5e5;
      border-radius: var(--radius);
      padding: 24px;
      text-decoration: none;
      color: var(--text);
      display: block;
      transition: all 0.2s;
    }
    .service-card:hover { border-color: var(--g700); box-shadow: var(--shadow); transform: translateY(-2px); }
    .service-card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 10px; }
    .service-emoji { font-size: 1.75rem; }
    .service-price-tag { font-size: 0.75rem; color: var(--g700); background: var(--g100); padding: 3px 8px; border-radius: 20px; font-weight: 700; white-space: nowrap; }
    .service-category { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 6px; }
    .service-name { font-size: 1rem; font-weight: 700; color: var(--g900); margin-bottom: 8px; line-height: 1.25; }
    .service-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.5; margin-bottom: 14px; }
    .service-cta { font-size: 0.8rem; font-weight: 700; color: var(--g700); display: flex; align-items: center; gap: 4px; }

    /* Local Info */
    .local-info { background: var(--g100); border: 1.5px solid var(--g700); border-radius: var(--radius); padding: 28px; margin-bottom: 40px; }
    .local-info h2 { font-size: 1.2rem; font-weight: 800; color: var(--g900); margin-bottom: 16px; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .info-item { background: #fff; border-radius: 8px; padding: 14px; }
    .info-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--g700); margin-bottom: 4px; }
    .info-value { font-size: 0.875rem; color: var(--g900); line-height: 1.45; }

    /* Nearby Areas */
    .nearby-section { margin-top: 0; }
    .nearby-section h2 { font-size: 1.2rem; font-weight: 800; color: var(--g900); margin-bottom: 16px; }
    .nearby-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .nearby-card { border: 1.5px solid #e5e5e5; border-radius: 8px; padding: 12px 14px; text-decoration: none; color: var(--text); font-size: 0.875rem; font-weight: 600; display: flex; align-items: center; gap: 8px; transition: all 0.2s; }
    .nearby-card:hover { border-color: var(--g700); background: var(--g100); color: var(--g800); }

    /* Sidebar */
    .sidebar { position: sticky; top: 80px; }
    .sidebar-card { background: #fff; border: 1.5px solid #e5e5e5; border-radius: var(--radius); padding: 20px; margin-bottom: 20px; }
    .sidebar-card.featured { background: var(--g800); color: #fff; border-color: var(--g800); }
    .sidebar-title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--g700); margin-bottom: 14px; border-bottom: 2px solid var(--g700); padding-bottom: 8px; }
    .sidebar-card.featured .sidebar-title { color: rgba(255,255,255,0.65); border-color: rgba(255,255,255,0.2); }
    .cta-headline { font-size: 1.05rem; font-weight: 800; margin-bottom: 8px; }
    .cta-body { font-size: 0.825rem; opacity: 0.85; line-height: 1.5; margin-bottom: 16px; }
    .btn-cta-w { display: block; text-align: center; background: var(--gold); color: #1a1a1a; padding: 12px; border-radius: 8px; font-weight: 700; font-size: 0.9rem; text-decoration: none; margin-bottom: 10px; }
    .btn-cta-outline { display: block; text-align: center; border: 2px solid rgba(255,255,255,0.3); color: rgba(255,255,255,0.9); padding: 10px; border-radius: 8px; font-weight: 700; font-size: 0.85rem; text-decoration: none; }
    .sidebar-links { display: flex; flex-direction: column; gap: 0; }
    .sidebar-link { display: flex; align-items: center; gap: 8px; text-decoration: none; color: var(--g700); font-size: 0.85rem; padding: 8px 0; border-bottom: 1px solid #eee; transition: color 0.2s; }
    .sidebar-link:last-child { border-bottom: none; }
    .sidebar-link:hover { color: var(--g900); }

    @media (max-width: 900px) {
      .page-wrap { grid-template-columns: 1fr; }
      .sidebar { position: static; }
      .hero-inner { grid-template-columns: 1fr; }
      .hero-stat-box { display: none; }
      .services-grid { grid-template-columns: 1fr; }
      .info-grid { grid-template-columns: 1fr; }
      .nearby-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      nav { display: none; }
    }
  </style>
</head>
<body>

<!-- Header -->
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <div class="logo-icon">🌵</div>
      <div>
        <div class="logo-text">Las Vegas Landscaping</div>
        <div class="logo-sub">Licensed • Insured</div>
      </div>
    </a>
    <nav>
      <a href="/#services">Services</a>
      <a href="/areas">Service Areas</a>
      <a href="/#estimate">Free Estimate</a>
      <a href="tel:7025288324" class="btn-call">📞 (702) 528-8324</a>
    </nav>
  </div>
</header>

<!-- Breadcrumb -->
<div class="breadcrumb">
  <div class="breadcrumb-inner">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/areas">Service Areas</a>
    <span>/</span>
    <strong>{city.name}</strong>
  </div>
</div>

<!-- Hero -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">📍 {city.name}, {city.state}</div>
      <h1>Landscaping Services<br />in {city.name}</h1>
      <p class="hero-desc">
        Serving {city.name} homeowners and businesses and we know the desert, the HOA rules, and the local contractors — bringing you the best outdoor spaces in the valley.
      </p>
      <div class="hero-badges">
        <span class="hero-badge">✅ Licensed & Insured</span>
        <span class="hero-badge">💧 AB356 Compliant</span>
        <span class="hero-badge">⭐ 4.9/5 — 500+ Reviews</span>
        <span class="hero-badge">📋 HOA Specialists</span>
      </div>
      <div class="hero-ctas">
        <a href="tel:7025288324" class="btn-gold">📞 Call (702) 528-8324</a>
        <a href="/#estimate" class="btn-outline-w">Get AI Estimate →</a>
      </div>
    </div>
    <div class="hero-stat-box">
      <div class="hero-stat-num">{services.length}</div>
      <div class="hero-stat-label">Services in<br />{city.name}</div>
    </div>
  </div>
</section>

<!-- Main -->
<div class="page-wrap">

  <!-- LEFT: Services + Local Info + Nearby -->
  <div>

    <!-- Services Grid -->
    <h2 style="font-size:1.5rem;font-weight:800;color:var(--g900);margin-bottom:20px">
      All Landscaping Services in {city.name}
    </h2>

    <div class="services-grid">
      {services.map(service => (
        <a href={`/areas/${citySlug}/${service.slug}`} class="service-card">
          <div class="service-card-top">
            <span class="service-emoji">{service.emoji}</span>
            <span class="service-price-tag">From {service.startingPrice}</span>
          </div>
          <div class="service-category">{service.category}</div>
          <div class="service-name">{service.name}</div>
          <div class="service-desc">{service.metaDesc}</div>
          <div class="service-cta">Get {city.name} estimate →</div>
        </a>
      ))}
    </div>

    <!-- Local Info Box -->
    <div class="local-info">
      <h2>📍 About Landscaping in {city.name}</h2>
      <div class="info-grid">
        <div class="info-item">
          <div class="info-label">Local Landscape Notes</div>
          <div class="info-value">{city.localNote}</div>
        </div>
        <div class="info-item">
          <div class="info-label">HOA Considerations</div>
          <div class="info-value">{city.hoaNote}</div>
        </div>
        <div class="info-item">
          <div class="info-label">Desert Climate</div>
          <div class="info-value">{city.climate}</div>
        </div>
        <div class="info-item">
          <div class="info-label">Nearby Areas We Also Serve</div>
          <div class="info-value">{city.nearbyAreas.join(', ')}</div>
        </div>
      </div>
    </div>

    <!-- Nearby Cities -->
    {nearbyCities.length > 0 && (
      <div class="nearby-section">
        <h2>Landscaping in Nearby Cities</h2>
        <div class="nearby-grid">
          {nearbyCities.map(c => (
            <a href={`/areas/${c.slug}`} class="nearby-card">
              📍 {c.name}
            </a>
          ))}
        </div>
      </div>
    )}

  </div>

  <!-- RIGHT: Sidebar -->
  <div class="sidebar">

    <!-- CTA Card -->
    <div class="sidebar-card featured">
      <div class="sidebar-title">Free Estimate</div>
      <div class="cta-headline">Get a Free AI Estimate for Your {city.name} Project</div>
      <div class="cta-body">Answer a few quick questions and get a detailed, AI-powered estimate in under 2 minutes.</div>
      <a href={`/areas/${citySlug}/${services[0].slug}`} class="btn-cta-w">🌵 Start Free Estimate</a>
      <a href="tel:7025288324" class="btn-cta-outline">📞 (702) 528-8324</a>
    </div>

    <!-- Services List -->
    <div class="sidebar-card">
      <div class="sidebar-title">All Services in {city.name}</div>
      <div class="sidebar-links">
        {services.map(s => (
          <a href={`/areas/${citySlug}/${s.slug}`} class="sidebar-link">
            <span>{s.emoji}</span>
            {s.shortName}
          </a>
        ))}
      </div>
    </div>

    <!-- All Cities -->
    <div class="sidebar-card">
      <div class="sidebar-title">Other Cities We Serve</div>
      <div class="sidebar-links">
        {cities.filter(c => c.slug !== citySlug).slice(0, 8).map(c => (
          <a href={`/areas/${c.slug}`} class="sidebar-link">
            <span>📍</span>
            {c.name}
          </a>
        ))}
        <a href="/areas" class="sidebar-link" style="font-weight:700;color:var(--g800)">
          <span>🗺️</span>
          View All {cities.length} Cities →
        </a>
      </div>
    </div>

  </div>

</div>

<!-- Footer -->
<footer style="background: var(--g900); color: rgba(255,255,255,0.7); text-align:center; padding: 24px; font-size: 0.8rem;">
  <div style="margin-bottom:8px">
    <a href="/areas" style="color:rgba(255,255,255,0.6);text-decoration:none;margin:0 8px">All Service Areas</a>
    <a href="/" style="color:rgba(255,255,255,0.6);text-decoration:none;margin:0 8px">Home</a>
    <a href="tel:7025288324" style="color:var(--gold2);text-decoration:none;font-weight:700;margin:0 8px">(702) 528-8324</a>
  </div>
  © {new Date().getFullYear()} Las Vegas Landscaping — Licensed • Insured<br />
  Landscaping Services in {city.name}, NV
</footer>

</body>
</html>
