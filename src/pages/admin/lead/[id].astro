---
export const prerender = false;
import { getLeadById, verifySession } from '../../../lib/db.js';

const sessionCookie = Astro.cookies.get('admin_session');
if (!verifySession(sessionCookie?.value)) {
  return Astro.redirect('/admin/login');
}

const { id } = Astro.params;
const lead = getLeadById(id);

if (!lead) {
  return Astro.redirect('/admin');
}

// Parse stored JSON safely
let quote = {};
let serviceAnswers = {};
try { quote = JSON.parse(lead.quote_json); } catch {}
try { serviceAnswers = JSON.parse(lead.service_answers); } catch {}

const statusOptions = [
  { value: 'new',       label: 'New',       color: '#1d4ed8' },
  { value: 'contacted', label: 'Contacted', color: '#a16207' },
  { value: 'quoted',    label: 'Quoted',    color: '#c2410c' },
  { value: 'won',       label: 'Won ✓',     color: '#166534' },
  { value: 'lost',      label: 'Lost',      color: '#6b7280' },
];

function fmtDate(iso) {
  return new Date(iso).toLocaleString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric',
    hour: 'numeric', minute: '2-digit'
  });
}

// Build ESRI satellite URL if address is present
let satelliteUrl = '';
if (lead.address) {
  // We store the address but not the lat/lon, so we use a server-side geocode
  // The admin page will do the geocoding client-side just like the estimate page did
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{lead.first_name} {lead.last_name} — Lead Detail</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #f4f6f8; color: #1a1a1a; }

    /* Header */
    .header {
      background: #1a4731;
      padding: 0 32px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .header-left { display: flex; align-items: center; gap: 16px; }
    .back-link { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.85rem; }
    .back-link:hover { color: #fff; }
    .header-title { color: #fff; font-weight: 700; font-size: 1rem; }
    .btn-logout {
      background: rgba(255,255,255,0.15); color: #fff;
      border: 1px solid rgba(255,255,255,0.25); border-radius: 6px;
      padding: 6px 14px; font-size: 0.8rem; cursor: pointer;
    }
    .btn-logout:hover { background: rgba(255,255,255,0.25); }

    /* Layout */
    .main { max-width: 1280px; margin: 0 auto; padding: 32px 24px; }
    .grid { display: grid; grid-template-columns: 300px 1fr 280px; gap: 24px; align-items: start; }

    /* Panels */
    .panel {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.07);
      overflow: hidden;
    }
    .panel-header {
      background: #f9fafb;
      border-bottom: 1px solid #f0f0f0;
      padding: 14px 20px;
      font-weight: 700;
      font-size: 0.85rem;
      color: #555;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .panel-body { padding: 20px; }

    /* Contact info */
    .info-row { margin-bottom: 14px; }
    .info-label { font-size: 0.72rem; color: #999; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 3px; }
    .info-val { font-size: 0.9rem; font-weight: 500; color: #1a1a1a; }
    .info-val a { color: #1a4731; text-decoration: none; }
    .info-val a:hover { text-decoration: underline; }

    .answer-row {
      background: #f9fafb;
      border-radius: 8px;
      padding: 10px 14px;
      margin-bottom: 8px;
    }
    .answer-q { font-size: 0.75rem; color: #888; margin-bottom: 2px; }
    .answer-a { font-size: 0.875rem; font-weight: 600; color: #1a1a1a; }

    /* Quote card — matches what customer saw */
    .quote-ready-badge {
      display: inline-flex; align-items: center; gap: 6px;
      background: #f0fdf4; color: #166534;
      border: 1px solid #bbf7d0;
      border-radius: 20px; padding: 4px 14px;
      font-size: 0.78rem; font-weight: 600;
      margin-bottom: 14px;
    }
    .quote-heading { font-size: 1.25rem; font-weight: 700; margin-bottom: 10px; }
    .quote-summary { font-size: 0.875rem; color: #555; margin-bottom: 20px; line-height: 1.6; }

    .price-box {
      background: #f0fdf4;
      border: 2px solid #bbf7d0;
      border-radius: 10px;
      padding: 16px 20px;
      margin-bottom: 6px;
    }
    .price-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: #888; margin-bottom: 4px; }
    .price-range { font-size: 1.6rem; font-weight: 800; color: #166534; }
    .price-duration { font-size: 0.78rem; color: #777; margin-top: 4px; }

    .line-items { margin: 20px 0; }
    .li-header {
      display: grid; grid-template-columns: 1fr 1fr 120px 100px;
      gap: 8px; padding: 8px 12px;
      background: #f9fafb; border-radius: 6px 6px 0 0;
      font-size: 0.7rem; font-weight: 700; color: #888;
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    .li-row {
      display: grid; grid-template-columns: 1fr 1fr 120px 100px;
      gap: 8px; padding: 12px 12px;
      border-bottom: 1px solid #f5f5f5;
      font-size: 0.85rem;
      align-items: start;
    }
    .li-row:last-child { border-bottom: none; }
    .li-service { font-weight: 600; }
    .li-desc { color: #666; font-size: 0.8rem; line-height: 1.4; }
    .li-price { color: #166534; font-weight: 600; font-size: 0.8rem; }
    .li-time { color: #888; font-size: 0.78rem; }

    .quote-section { margin-top: 16px; }
    .quote-section-title {
      font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em;
      color: #888; font-weight: 700; margin-bottom: 8px;
    }
    .quote-section p { font-size: 0.85rem; color: #555; line-height: 1.6; }
    .next-steps li { font-size: 0.85rem; color: #555; margin-left: 18px; margin-bottom: 4px; }
    .disclaimer { font-size: 0.75rem; color: #aaa; font-style: italic; margin-top: 16px; }

    /* Satellite panel */
    .sat-wrap {
      position: relative;
      border-radius: 8px;
      overflow: hidden;
      height: 180px;
      background: #0a1a10;
      border: 1.5px solid rgba(0,255,80,0.3);
      margin-bottom: 16px;
    }
    #sat-img {
      width: 100%; height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 0.5s;
    }
    .sat-overlay {
      position: absolute; inset: 0;
      pointer-events: none;
    }
    .sat-corner {
      position: absolute; width: 12px; height: 12px;
      border-color: rgba(0,255,80,0.8); border-style: solid;
    }
    .sat-corner-tl { top: 6px; left: 6px;  border-width: 2px 0 0 2px; }
    .sat-corner-tr { top: 6px; right: 6px; border-width: 2px 2px 0 0; }
    .sat-corner-bl { bottom: 6px; left: 6px;  border-width: 0 0 2px 2px; }
    .sat-corner-br { bottom: 6px; right: 6px; border-width: 0 2px 2px 0; }
    .sat-label {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: rgba(0,0,0,0.7);
      padding: 4px 8px;
      font-size: 0.65rem;
      font-family: 'Courier New', monospace;
      color: rgba(0,255,80,0.9);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .no-address { color: #aaa; font-size: 0.82rem; text-align: center; padding: 20px; }

    /* Status & notes */
    select {
      width: 100%; border: 1.5px solid #ddd; border-radius: 8px;
      padding: 8px 12px; font-size: 0.875rem;
      margin-bottom: 12px; outline: none;
    }
    select:focus { border-color: #2d6b4e; }
    textarea {
      width: 100%; border: 1.5px solid #ddd; border-radius: 8px;
      padding: 10px 12px; font-size: 0.85rem;
      resize: vertical; min-height: 90px;
      margin-bottom: 12px; outline: none;
      font-family: inherit;
    }
    textarea:focus { border-color: #2d6b4e; }
    .save-btn {
      width: 100%; background: #1a4731; color: #fff;
      border: none; border-radius: 8px; padding: 10px;
      font-size: 0.875rem; font-weight: 700; cursor: pointer;
    }
    .save-btn:hover { background: #2d6b4e; }
    .save-btn:disabled { opacity: 0.5; }
    .save-ok { color: #166534; font-size: 0.8rem; text-align: center; margin-top: 8px; display: none; }

    @media (max-width: 1024px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<header class="header">
  <div class="header-left">
    <a class="back-link" href="/admin">← All Leads</a>
    <span style="color:rgba(255,255,255,0.3)">|</span>
    <span class="header-title">{lead.first_name} {lead.last_name}</span>
  </div>
  <button class="btn-logout" id="logout-btn">Sign Out</button>
</header>

<main class="main">
  <div style="font-size:0.82rem;color:#888;margin-bottom:20px">
    Submitted: {fmtDate(lead.created_at)} &nbsp;·&nbsp; Lead ID: <code style="font-size:0.78rem;background:#eee;padding:1px 6px;border-radius:4px">{lead.id}</code>
  </div>

  <div class="grid">

    <!-- ── Left: Contact + Answers ── -->
    <div>
      <div class="panel" style="margin-bottom:16px">
        <div class="panel-header">Contact Info</div>
        <div class="panel-body">
          <div class="info-row">
            <div class="info-label">Name</div>
            <div class="info-val">{lead.first_name} {lead.last_name || ''}</div>
          </div>
          <div class="info-row">
            <div class="info-label">Phone</div>
            <div class="info-val"><a href={`tel:${lead.phone}`}>{lead.phone}</a></div>
          </div>
          {lead.email && (
            <div class="info-row">
              <div class="info-label">Email</div>
              <div class="info-val"><a href={`mailto:${lead.email}`}>{lead.email}</a></div>
            </div>
          )}
          <div class="info-row">
            <div class="info-label">Service</div>
            <div class="info-val">{lead.service}</div>
          </div>
          <div class="info-row">
            <div class="info-label">City</div>
            <div class="info-val">{lead.city}</div>
          </div>
          {lead.address && (
            <div class="info-row">
              <div class="info-label">Property Address</div>
              <div class="info-val">{lead.address}</div>
            </div>
          )}
          {lead.customer_notes && (
            <div class="info-row">
              <div class="info-label">Customer Notes</div>
              <div class="info-val" style="color:#555;font-size:0.85rem">{lead.customer_notes}</div>
            </div>
          )}
        </div>
      </div>

      {Object.keys(serviceAnswers).length > 0 && (
        <div class="panel">
          <div class="panel-header">Project Answers</div>
          <div class="panel-body">
            {Object.entries(serviceAnswers).map(([q, a]) => (
              <div class="answer-row">
                <div class="answer-q">{q}</div>
                <div class="answer-a">{a}</div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- ── Center: Quote (exactly what customer saw) ── -->
    <div class="panel">
      <div class="panel-header">Estimate — Exactly What Customer Saw</div>
      <div class="panel-body">

        {!quote.totalRange ? (
          <p style="color:#aaa;text-align:center;padding:32px">No quote data available for this lead.</p>
        ) : (
          <>
            <div class="quote-ready-badge">✓ Your estimate is ready!</div>
            <div class="quote-heading">{lead.first_name}, here's your {lead.city} estimate!</div>
            <div class="quote-summary">{quote.summary}</div>

            <div class="price-box">
              <div class="price-label">Estimated Total Range</div>
              <div class="price-range">{quote.totalRange}</div>
              {quote.projectTimeline && (
                <div class="price-duration">Project Duration: {quote.projectTimeline}</div>
              )}
            </div>

            {quote.lineItems && quote.lineItems.length > 0 && (
              <div class="line-items">
                <div class="li-header">
                  <span>Service</span>
                  <span>Description</span>
                  <span>Price Range</span>
                  <span>Timeline</span>
                </div>
                {quote.lineItems.map(item => (
                  <div class="li-row">
                    <span class="li-service">{item.service}</span>
                    <span class="li-desc">{item.description}</span>
                    <span class="li-price">{item.priceRange}</span>
                    <span class="li-time">{item.timeline}</span>
                  </div>
                ))}
              </div>
            )}

            {quote.lasVegasNotes && (
              <div class="quote-section">
                <div class="quote-section-title">📍 Local Notes</div>
                {Array.isArray(quote.lasVegasNotes)
                  ? <ul class="next-steps">{quote.lasVegasNotes.map(n => <li>{n}</li>)}</ul>
                  : <p>{quote.lasVegasNotes}</p>
                }
              </div>
            )}

            {quote.nextSteps && (
              <div class="quote-section">
                <div class="quote-section-title">Next Steps</div>
                {Array.isArray(quote.nextSteps)
                  ? <ul class="next-steps">{quote.nextSteps.map(step => <li>{step}</li>)}</ul>
                  : <p>{quote.nextSteps}</p>
                }
              </div>
            )}

            {quote.disclaimer && (
              <div class="disclaimer">{quote.disclaimer}</div>
            )}
          </>
        )}
      </div>
    </div>

    <!-- ── Right: Satellite + Status + Notes ── -->
    <div>

      <!-- Satellite -->
      <div class="panel" style="margin-bottom:16px">
        <div class="panel-header">Satellite View</div>
        <div class="panel-body" style="padding:12px">
          {lead.address ? (
            <>
              <div class="sat-wrap">
                <img id="sat-img" src="" alt="Satellite view" />
                <div class="sat-overlay">
                  <div class="sat-corner sat-corner-tl"></div>
                  <div class="sat-corner sat-corner-tr"></div>
                  <div class="sat-corner sat-corner-bl"></div>
                  <div class="sat-corner sat-corner-br"></div>
                  <div class="sat-label" id="sat-label">{lead.address.toUpperCase()}</div>
                </div>
              </div>
              <div style="font-size:0.75rem;color:#aaa;text-align:center">{lead.address}</div>
            </>
          ) : (
            <div class="no-address">No property address provided</div>
          )}
        </div>
      </div>

      <!-- Status -->
      <div class="panel">
        <div class="panel-header">Status & Notes</div>
        <div class="panel-body">
          <div style="font-size:0.75rem;color:#888;margin-bottom:6px;font-weight:600">LEAD STATUS</div>
          <select id="status-select">
            {statusOptions.map(opt => (
              <option value={opt.value} selected={opt.value === lead.status}>{opt.label}</option>
            ))}
          </select>

          <div style="font-size:0.75rem;color:#888;margin-bottom:6px;font-weight:600">ADMIN NOTES</div>
          <textarea id="admin-notes" placeholder="Add private notes about this lead…">{lead.admin_notes}</textarea>

          <button class="save-btn" id="save-btn">Save Changes</button>
          <div class="save-ok" id="save-ok">✓ Saved successfully</div>
        </div>
      </div>

    </div>
  </div>
</main>

<script is:inline define:vars={{ leadId: lead.id, leadAddress: lead.address }}>
  // Logout
  document.getElementById('logout-btn').addEventListener('click', async () => {
    await fetch('/api/admin/logout', { method: 'POST' });
    window.location.href = '/admin/login';
  });

  // Save status + notes
  document.getElementById('save-btn').addEventListener('click', async () => {
    const btn    = document.getElementById('save-btn');
    const okEl   = document.getElementById('save-ok');
    const status = document.getElementById('status-select').value;
    const notes  = document.getElementById('admin-notes').value;

    btn.disabled = true;
    btn.textContent = 'Saving…';
    okEl.style.display = 'none';

    try {
      const res = await fetch('/api/admin/update-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: leadId, status, admin_notes: notes }),
      });
      if (res.ok) {
        okEl.style.display = 'block';
        setTimeout(() => { okEl.style.display = 'none'; }, 3000);
      }
    } finally {
      btn.disabled = false;
      btn.textContent = 'Save Changes';
    }
  });

  // Load satellite image if address present
  if (leadAddress) {
    (async () => {
      try {
        const geoRes = await fetch(
          `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(leadAddress)}&format=json&limit=1&countrycodes=us`,
          { headers: { 'Accept-Language': 'en-US,en' } }
        );
        const geoData = await geoRes.json();
        if (geoData && geoData.length > 0) {
          const lat = parseFloat(geoData[0].lat);
          const lon = parseFloat(geoData[0].lon);
          const delta = 0.0012;
          const bbox = `${lon - delta},${lat - delta},${lon + delta},${lat + delta}`;
          const esriUrl =
            `https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/export` +
            `?bbox=${bbox}&bboxSR=4326&imageSR=4326&size=560,320&format=jpg&f=image`;
          const img = document.getElementById('sat-img');
          if (img) {
            img.onload = () => { img.style.opacity = '1'; };
            img.src = esriUrl;
          }
        }
      } catch {}
    })();
  }
</script>
</body>
</html>
