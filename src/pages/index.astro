.contact-list li { font-size: 0.8125rem; }
.contact-list a { color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.15s; }
.contact-list a:hover { color: white; }
.hours-list li { font-size: 0.8125rem; color: rgba(255,255,255,0.6); margin-bottom: 6px; }
.footer-cta {
  display: block; text-align: center;
  background: var(--gold); color: var(--gray9);
  font-weight: 700; font-size: 0.875rem;
  padding: 11px 16px; border-radius: 8px;
  text-decoration: none; margin-bottom: 16px;
  transition: background 0.15s;
}
.footer-cta:hover { background: var(--gold2); }
.footer-payment { font-size: 0.75rem; }
.payment-label { color: rgba(255,255,255,0.5); display: block; margin-bottom: 4px; }
.payment-methods { color: rgba(255,255,255,0.7); }
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.07);
  padding: 18px 0;
}
.footer-bottom-inner {
  display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
  font-size: 0.75rem; color: rgba(255,255,255,0.4);
}
</style>

<script>
// ── State ────────────────────────────────────────────────────────────
const state = { step: 1, services: [], property: {}, contact: {} };

// ── Utility ──────────────────────────────────────────────────────────
function showError(id, msg) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = msg;
  el.classList.add('visible');
  setTimeout(() => el.classList.remove('visible'), 5000);
}
function clearError(id) { document.getElementById(id)?.classList.remove('visible'); }

function goToStep(n) {
  document.querySelectorAll('.form-step').forEach(el => el.classList.add('hidden'));
  document.getElementById(`step-${n}`)?.classList.remove('hidden');

  document.querySelectorAll('#stepper .step').forEach(el => {
    const s = parseInt(el.dataset.step || '0');
    el.classList.remove('active', 'completed');
    if (s === n) el.classList.add('active');
    if (s < n) el.classList.add('completed');
  });
  document.getElementById('line-1')?.classList.toggle('active', n > 1);
  document.getElementById('line-2')?.classList.toggle('active', n > 2);

  state.step = n;
  document.getElementById('estimate')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ── Service Checkboxes ────────────────────────────────────────────────
function initServices() {
  document.querySelectorAll('.service-item input[type="checkbox"]').forEach(cb => {
    cb.addEventListener('change', () => {
      const val = cb.value;
      state.services = cb.checked
        ? [...new Set([...state.services, val])]
        : state.services.filter(s => s !== val);
      const count = state.services.length;
      const el = document.getElementById('service-count');
      if (el) el.textContent = count > 0 ? `${count} service${count !== 1 ? 's' : ''} selected` : '';
      clearError('step1-error');
    });
  });
}

// ── Radio Groups ──────────────────────────────────────────────────────
function initRadioGroups() {
  document.querySelectorAll('.radio-group').forEach(group => {
    group.querySelectorAll('.radio-item').forEach(item => {
      const radio = item.querySelector('input[type="radio"]');
      if (!radio) return;
      if (radio.checked) item.classList.add('selected');
      item.addEventListener('click', () => {
        document.querySelectorAll(`input[name="${radio.name}"]`)
          .forEach(r => r.closest('.radio-item')?.classList.remove('selected'));
        radio.checked = true;
        item.classList.add('selected');
      });
    });
  });
}

// ── Collect ───────────────────────────────────────────────────────────
function collectProperty() {
  state.property = {
    address:      document.getElementById('address')?.value?.trim() || '',
    propertyType: document.querySelector('input[name="propertyType"]:checked')?.value || 'Residential - Single Family',
    lotSize:      document.getElementById('lotSize')?.value || '',
    timeline:     document.getElementById('timeline')?.value || '',
    condition:    document.getElementById('condition')?.value || '',
    hoa:          document.querySelector('input[name="hoa"]:checked')?.value || 'Not sure'
  };
}
function collectContact() {
  state.contact = {
    firstName:     document.getElementById('firstName')?.value?.trim() || '',
    lastName:      document.getElementById('lastName')?.value?.trim() || '',
    phone:         document.getElementById('phone')?.value?.trim() || '',
    email:         document.getElementById('email')?.value?.trim() || '',
    contactMethod: document.querySelector('input[name="contactMethod"]:checked')?.value || 'Text message',
    notes:         document.getElementById('notes')?.value?.trim() || ''
  };
}

// ── Validate ──────────────────────────────────────────────────────────
function validateStep1() {
  if (!state.services.length) { showError('step1-error', 'Please select at least one service to continue.'); return false; }
  return true;
}
function validateStep2() {
  collectProperty();
  if (!state.property.address) { showError('step2-error', 'Please enter your property address.'); return false; }
  return true;
}
function validateStep3() {
  collectContact();
  if (!state.contact.firstName) { showError('step3-error', 'Please enter your first name.'); return false; }
  if (!state.contact.phone && !state.contact.email) { showError('step3-error', 'Please provide a phone number or email so we can reach you.'); return false; }
  return true;
}

// ── Submit ────────────────────────────────────────────────────────────
function startLoadingAnim() {
  ['ls-1','ls-2','ls-3'].forEach(id => document.getElementById(id)?.classList.remove('active'));
  let i = 0;
  const ids = ['ls-1','ls-2','ls-3'];
  const tick = () => {
    if (i < ids.length) { document.getElementById(ids[i])?.classList.add('active'); i++; if (i < ids.length) setTimeout(tick, 1600); }
  };
  setTimeout(tick, 400);
}

async function submitForm() {
  if (!validateStep3()) return;
  document.getElementById('step-3')?.classList.add('hidden');
  document.getElementById('step-loading')?.classList.remove('hidden');
  const stepper = document.getElementById('stepper');
  if (stepper) stepper.style.opacity = '0.3';
  startLoadingAnim();

  try {
    const res = await fetch('/api/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ services: state.services, property: state.property, contact: state.contact })
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    if (!data.estimate) throw new Error('No estimate returned');
    renderResults(data.estimate);
  } catch (err) {
    console.error(err);
    document.getElementById('step-loading')?.classList.add('hidden');
    document.getElementById('step-3')?.classList.remove('hidden');
    if (stepper) stepper.style.opacity = '1';
    showError('step3-error', 'Something went wrong. Please try again or call us at (702) 528-8324.');
  }
}

// ── Results ───────────────────────────────────────────────────────────
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function renderResults(est) {
  document.getElementById('step-loading')?.classList.add('hidden');
  document.getElementById('step-results')?.classList.remove('hidden');

  const name = state.contact.firstName;
  const nameEl = document.getElementById('result-name');
  if (nameEl) nameEl.textContent = name ? `${name}, here's your estimate!` : 'Your Estimate Is Ready';

  ['result-summary','result-total','result-timeline','result-next-steps','result-disclaimer'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    if (id === 'result-total') el.textContent = est.totalRange || 'Contact us for details';
    else if (id === 'result-timeline') el.textContent = est.projectTimeline || '';
    else if (id === 'result-summary') el.textContent = est.summary || '';
    else if (id === 'result-next-steps') el.textContent = est.nextSteps || 'Our team will reach out within 24 hours to schedule your free on-site consultation.';
    else if (id === 'result-disclaimer') el.textContent = est.disclaimer || '';
  });

  const lineEl = document.getElementById('result-line-items');
  if (lineEl && est.lineItems?.length) {
    lineEl.innerHTML = est.lineItems.map(item => `
      <div class="line-item">
        <div class="line-item-info">
          <h4>${esc(item.service || '')}</h4>
          <p>${esc(item.description || '')}</p>
          ${item.timeline ? `<div class="line-item-timeline">Timeline: ${esc(item.timeline)}</div>` : ''}
        </div>
        <div class="line-item-price"><div class="price-range">${esc(item.priceRange || '')}</div></div>
      </div>`).join('');
  }

  const notesEl = document.getElementById('result-notes');
  const notesSec = document.getElementById('lv-notes-section');
  if (notesEl && notesSec && est.lasVegasNotes?.length) {
    notesEl.innerHTML = est.lasVegasNotes.map(n => `<li>${esc(n)}</li>`).join('');
    notesSec.style.display = 'block';
  } else if (notesSec) notesSec.style.display = 'none';

  document.getElementById('estimate')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ── Reset ─────────────────────────────────────────────────────────────
function resetForm() {
  state.services = []; state.property = {}; state.contact = {};
  document.querySelectorAll('input[type="checkbox"]').forEach(cb => { cb.checked = false; });
  document.querySelectorAll('input[type="text"], input[type="tel"], input[type="email"], textarea').forEach(el => { el.value = ''; });
  document.querySelectorAll('.radio-item').forEach(el => el.classList.remove('selected'));
  [['propertyType','Residential - Single Family'],['hoa','Not sure'],['contactMethod','Text message']].forEach(([name, val]) => {
    const el = document.querySelector(`input[name="${name}"][value="${val}"]`);
    if (el) { el.checked = true; el.closest('.radio-item')?.classList.add('selected'); }
  });
  const sc = document.getElementById('service-count');
  if (sc) sc.textContent = '';
  const stepper = document.getElementById('stepper');
  if (stepper) stepper.style.opacity = '1';
  goToStep(1);
}

// ── FAQ Accordion ─────────────────────────────────────────────────────
function initFAQ() {
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.faq-item').forEach(i => { i.classList.remove('open'); i.querySelector('.faq-q').setAttribute('aria-expanded','false'); });
      // Open clicked if it was closed
      if (!isOpen) { item.classList.add('open'); btn.setAttribute('aria-expanded','true'); }
    });
  });
}

// ── Mobile Nav ────────────────────────────────────────────────────────
function initMobileNav() {
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('mobile-nav');
  if (!toggle || !nav) return;
  toggle.addEventListener('click', () => {
    const open = nav.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    nav.setAttribute('aria-hidden', open ? 'false' : 'true');
  });
  nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    nav.classList.remove('open');
    toggle.setAttribute('aria-expanded','false');
    nav.setAttribute('aria-hidden','true');
  }));
}

// ── Boot ──────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  initServices();
  initRadioGroups();
  initFAQ();
  initMobileNav();

  document.getElementById('btn-step1-next')?.addEventListener('click', () => { if (validateStep1()) goToStep(2); });
  document.getElementById('btn-step2-back')?.addEventListener('click', () => goToStep(1));
  document.getElementById('btn-step2-next')?.addEventListener('click', () => { if (validateStep2()) goToStep(3); });
  document.getElementById('btn-step3-back')?.addEventListener('click', () => goToStep(2));
  document.getElementById('btn-step3-submit')?.addEventListener('click', submitForm);
  document.getElementById('btn-start-over')?.addEventListener('click', resetForm);

  ['address','firstName','phone','email'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', () => { clearError('step2-error'); clearError('step3-error'); });
  });
});
</script>
